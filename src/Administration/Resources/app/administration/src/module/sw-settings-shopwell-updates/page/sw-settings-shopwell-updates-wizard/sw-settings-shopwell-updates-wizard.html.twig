{% block sw_settings_shopwell_updates_wizard %}
<sw-page class="sw-settings-shopwell-updates-wizard">
    {% block sw_settings_shopwell_updates_wizard_smart_bar_header %}
    <template #smart-bar-header>
        <h2 v-if="updateInfo.version">
            {{ $t('sw-settings-shopwell-updates.general.title', {version: updateInfo.version }) }}
        </h2>
        <h2 v-if="!updateInfo.version">
            {{ $t('sw-settings-shopwell-updates.general.emptyTitle') }}
        </h2>
    </template>
    {% endblock %}

    {% block sw_settings_shopwell_updates_wizard_smart_bar_actions %}
    <template #smart-bar-actions>
        <div
            :key="updatePossible"
            v-tooltip="updateButtonTooltip"
        >
            <mt-button
                v-if="updateInfo.version"
                :disabled="!updatePossible"
                :is-loading="updaterIsRunning"
                variant="primary"
                class="sw-settings-shopwell-updates-wizard__start-update"
                size="default"
                @click="updateModalShown = true"
            >
                {{ $t('sw-settings-shopwell-updates.infos.startUpdate') }}
            </mt-button>
        </div>
    </template>
    {% endblock %}

    <template #content>
        <div class="sw-settings-shopwell-updates-wizard__content">
        {% block sw_settings_shopwell_updates_wizard_content %}
            <sw-card-view v-if="isLoading || updateInfo.version">
                <sw-settings-shopwell-updates-info
                    v-if="updateInfo"
                    :is-loading="isLoading"
                    :changelog="updateInfo.body"
                />
                <sw-settings-shopwell-updates-requirements
                    :is-loading="isLoading"
                    :update-info="updateInfo"
                    :requirements="requirements"
                />
                <sw-settings-shopwell-updates-plugins
                    :plugins="plugins"
                    :is-loading="isLoading"
                />
            </sw-card-view>

            <mt-empty-state
                v-if="!isLoading && !updateInfo.version"
                :centered="true"
                :icon="$route.meta.$module.icon"
                :headline="$tc('sw-settings-shopwell-updates.general.emptyState')"
            />

            <sw-modal
                v-if="updaterIsRunning"
                :title="$t('sw-settings-shopwell-updates.cards.updating')"
                variant="small"
                class="sw-shopwell-updates-progressbar"
            >
                <div class="progress-wrapper">
                    <mt-progress-bar
                        :model-value="progressbarValue"
                        :max-value="100"
                    />
                    <span class="progress-title">
                        <p v-if="step === 'download'">{{ $t('sw-settings-shopwell-updates.infos.progress.download') }}</p>
                        <p v-if="step === 'unpack'">{{ $t('sw-settings-shopwell-updates.infos.progress.unpack') }}</p>
                        <p v-if="step === 'deactivate'">{{ $t('sw-settings-shopwell-updates.infos.progress.deactivate') }}</p>
                    </span>
                </div>
            </sw-modal>

            <sw-modal
                v-if="updateModalShown"
                class="sw-settings-shopwell-updates-check__start-update"
                :title="$t('sw-settings-shopwell-updates.general.emptyTitle')"
                variant="small"
                @modal-close="updateModalShown = false"
            >
                <mt-banner
                    v-if="displayUnknownPluginsWarning"
                    variant="attention"
                >
                    {{ $tc('sw-settings-shopwell-updates.updateModal.messageNotInStore') }}
                </mt-banner>

                <mt-banner
                    v-if="displayIncompatiblePluginsWarning"
                    variant="attention"
                >
                    {{ $tc('sw-settings-shopwell-updates.updateModal.messageIncompatible') }}
                </mt-banner>

                <sw-radio-field
                    v-if="displayIncompatiblePluginsWarning"
                    v-model:value="chosenPluginBehaviour"
                    :options="[
                        {'value': 'all', 'name': optionDeactivateAllTranslation },
                        {'value': 'notCompatible', 'name': optionDeactivateIncompatibleTranslation },
                        {'value': '', 'name': $tc('sw-settings-shopwell-updates.plugins.actions.deactivateNone')}]"
                />

                <template v-if="displayAllPluginsOkayInfo">
                    {{ $tc('sw-settings-shopwell-updates.updateModal.messageOkay') }}
                </template>

                <template #modal-footer>
                    <mt-checkbox
                        v-model:checked="checkedBackupCheckbox"
                        class="sw-settings-shopwell-updates-check__start-update-backup-checkbox"
                        :label="$tc('sw-settings-shopwell-updates.updateModal.backupLabel')"
                    />

                    <div class="sw-settings-shopwell-updates-check__start-update-actions">
                        <mt-button
                            size="small"
                            variant="secondary"
                            @click="updateModalShown = false"
                        >
                            {{ $tc('global.default.cancel') }}
                        </mt-button>

                        <mt-button
                            :disabled="!checkedBackupCheckbox"
                            variant="primary"
                            size="small"
                            class="sw-settings-shopwell-updates-check__start-update-button"
                            @click="startUpdateProcess()"
                        >
                            {{ $tc('sw-settings-shopwell-updates.updateModal.actions.install') }}
                        </mt-button>
                    </div>
                </template>
            </sw-modal>
        {% endblock %}
        </div>
    </template>
</sw-page>
{% endblock %}
