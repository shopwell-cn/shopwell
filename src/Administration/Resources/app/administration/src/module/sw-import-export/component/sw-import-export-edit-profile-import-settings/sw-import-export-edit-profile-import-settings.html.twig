{% block sw_import_export_edit_profile_import_settings %}
<div class="sw-import-export-edit-profile-import-settings">
    {% block sw_import_export_edit_profile_import_settings_headline %}
    <h3 class="sw-import-export-edit-profile-import-settings__headline">
        {{ $tc('sw-import-export.profile.importSettingsHeadline') }}
    </h3>
    {% endblock %}

    <div class="sw-import-export-edit-profile-import-settings__container">
        {% block sw_import_export_edit_profile_import_settings_create_switch %}
        <mt-switch
            :model-value="profile.config.createEntities"
            class="sw-import-export-edit-profile-import-settings__create-switch"
            :label="$tc('sw-import-export.profile.createEntitiesLabel')"
            :disabled="profile.systemDefault"
            @update:model-value="onChange($event, 'createEntities')"
        />
        {% endblock %}

        {% block sw_import_export_edit_profile_import_settings_update_switch %}
        <mt-switch
            :model-value="profile.config.updateEntities"
            class="sw-import-export-edit-profile-import-settings__update-switch"
            :label="$tc('sw-import-export.profile.updateEntitiesLabel')"
            :disabled="profile.systemDefault"
            @update:model-value="onChange($event, 'updateEntities')"
        />
        {% endblock %}
    </div>
</div>
{% endblock %}
