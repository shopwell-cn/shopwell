<?xml version="1.0" ?>

<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">

    <parameters>
        <parameter key="env(SHOPWELL_ADMINISTRATION_PATH_NAME)">admin</parameter>
        <parameter key="shopwell_administration.path_name">%env(resolve:SHOPWELL_ADMINISTRATION_PATH_NAME)%</parameter>
    </parameters>

    <services>
        <service id="Shopwell\Administration\Command\DeleteAdminFilesAfterBuildCommand">
            <argument type="service" id="Symfony\Component\Filesystem\Filesystem"/>
            <tag name="console.command"/>
        </service>

        <service id="Shopwell\Administration\Command\DeleteExtensionLocalPublicFilesCommand">
            <argument type="service" id="kernel"/>
            <tag name="console.command"/>
        </service>

        <service id="Shopwell\Administration\Controller\AdminExtensionApiController" public="true">
            <argument type="service" id="Shopwell\Core\Framework\App\ActionButton\Executor"/>
            <argument type="service" id="Shopwell\Core\Framework\App\Payload\AppPayloadServiceHelper"/>
            <argument type="service" id="app.repository"/>
            <argument type="service" id="Shopwell\Core\Framework\App\Hmac\QuerySigner"/>

            <call method="setContainer">
                <argument type="service" id="service_container"/>
            </call>
        </service>

        <service id="Shopwell\Administration\Controller\AdministrationController"
                 public="true">
            <argument type="service" id="Shopwell\Core\Framework\Adapter\Twig\TemplateFinder"/>
            <argument type="service" id="Shopwell\Core\Framework\Store\Services\FirstRunWizardService"/>
            <argument type="service" id="Shopwell\Administration\Snippet\SnippetFinder"/>
            <argument>%kernel.supported_api_versions%</argument>
            <argument type="service" id="Shopwell\Administration\Framework\Routing\KnownIps\KnownIpsCollector"/>
            <argument type="service" id="Doctrine\DBAL\Connection"/>
            <argument type="service" id="event_dispatcher"/>
            <argument>%kernel.shopwell_core_dir%</argument>
            <argument type="service" id="customer.repository"/>
            <argument type="service" id="currency.repository"/>
            <argument type="service" id="Shopwell\Core\Framework\Util\HtmlSanitizer"/>
            <argument type="service" id="Shopwell\Core\Framework\DataAbstractionLayer\DefinitionInstanceRegistry"/>
            <argument type="service" id="parameter_bag"/>
            <argument type="service" id="Shopwell\Core\System\SystemConfig\SystemConfigService"/>
            <argument type="service" id="shopwell.filesystem.asset"/>
            <argument type="string">%env(SERVICE_REGISTRY_URL)%</argument>
            <argument type="service" id="language.repository"/>
            <argument type="service" id="Shopwell\Core\Framework\Api\OAuth\SymfonyBearerTokenValidator"/>
            <argument type="string">%env(PRODUCT_ANALYTICS_GATEWAY_URL)%</argument>
            <argument type="string">%shopwell.api.refresh_token_ttl%</argument>

            <call method="setContainer">
                <argument type="service" id="service_container"/>
            </call>
        </service>

        <service id="Shopwell\Administration\Controller\AdminSearchController" public="true">
            <argument type="service" id="Shopwell\Core\Framework\DataAbstractionLayer\Search\RequestCriteriaBuilder"/>
            <argument type="service" id="Shopwell\Core\Framework\DataAbstractionLayer\DefinitionInstanceRegistry"/>
            <argument type="service" id="Shopwell\Administration\Service\AdminSearcher"/>
            <argument type="service" id="serializer"/>
            <argument type="service" id="Shopwell\Core\Framework\Api\Acl\AclCriteriaValidator"/>
            <argument type="service" id="Shopwell\Core\Framework\DataAbstractionLayer\DefinitionInstanceRegistry"/>
            <argument type="service" id="Shopwell\Core\Framework\Api\Serializer\JsonEntityEncoder"/>

            <call method="setContainer">
                <argument type="service" id="service_container"/>
            </call>
        </service>

        <service id="Shopwell\Administration\Controller\UserConfigController" public="true">
            <argument type="service" id="user_config.repository"/>
            <argument type="service" id="Doctrine\DBAL\Connection"/>

            <call method="setContainer">
                <argument type="service" id="service_container"/>
            </call>
        </service>

        <service id="Shopwell\Administration\Controller\AdminProductStreamController"
                 public="true">
            <argument type="service" id="Shopwell\Core\Content\Product\ProductDefinition"/>
            <argument type="service" id="sales_channel.product.repository"/>
            <argument type="service" id="Shopwell\Core\System\SalesChannel\Context\SalesChannelContextService"/>
            <argument type="service" id="Shopwell\Core\Framework\DataAbstractionLayer\Search\RequestCriteriaBuilder"/>

            <call method="setContainer">
                <argument type="service" id="service_container"/>
            </call>
        </service>

        <service id="Shopwell\Administration\Controller\AdminTagController"
                 public="true">
            <argument type="service" id="Shopwell\Core\System\Tag\Service\FilterTagIdsService"/>

            <call method="setContainer">
                <argument type="service" id="service_container"/>
            </call>
        </service>

        <service id="Shopwell\Administration\Controller\NotificationController" public="true">
            <argument type="service" id="shopwell.rate_limiter"/>
            <argument type="service" id="Shopwell\Core\Framework\Notification\NotificationService"/>

            <call method="setContainer">
                <argument type="service" id="service_container"/>
            </call>
        </service>

        <service id="Shopwell\Administration\Service\AdminSearcher">
            <argument type="service" id="Shopwell\Core\Framework\DataAbstractionLayer\DefinitionInstanceRegistry"/>
        </service>

        <service id="Shopwell\Administration\Framework\Routing\NotFound\AdministrationNotFoundSubscriber">
            <argument>%shopwell_administration.path_name%</argument>
            <argument type="service" id="service_container" />

            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Shopwell\Administration\Framework\Routing\AdministrationRouteScope">
            <argument>%shopwell_administration.path_name%</argument>
            <tag name="shopwell.route_scope"/>
        </service>

        <service id="Shopwell\Administration\Framework\SystemCheck\AdministrationReadinessCheck">
            <argument type="service" id="Symfony\Component\Routing\RouterInterface"/>
            <argument type="service" id="Symfony\Component\HttpKernel\KernelInterface"/>
            <argument type="service" id="Shopwell\Administration\Framework\Twig\ViteFileAccessorDecorator"/>
            <argument type="service" id="filesystem"/>

            <tag name="shopwell.system_check"/>
        </service>

        <service id="Shopwell\Administration\Snippet\AppAdministrationSnippetDefinition">
            <tag name="shopwell.entity.definition"/>
        </service>

        <service id="Shopwell\Administration\Snippet\AppAdministrationSnippetPersister">
            <argument type="service" id="app_administration_snippet.repository"/>
            <argument type="service" id="locale.repository"/>
            <argument type="service" id="Shopwell\Core\Framework\Adapter\Cache\CacheInvalidator"/>
            <argument type="service" id="Symfony\Component\Filesystem\Filesystem"/>
        </service>

        <service id="Shopwell\Administration\Snippet\SnippetFinder">
            <argument type="service" id="kernel" />
            <argument type="service" id="Doctrine\DBAL\Connection"/>
            <argument type="service" id="shopwell.filesystem.private"/>
            <argument type="service" id="Shopwell\Core\System\Snippet\Struct\TranslationConfig"/>
            <argument type="service" id="Shopwell\Core\System\Snippet\Service\TranslationLoader"/>
            <argument type="service" id="Shopwell\Core\Framework\Util\HtmlSanitizer"/>
        </service>

        <service id="Shopwell\Administration\Snippet\CachedSnippetFinder" decorates="Shopwell\Administration\Snippet\SnippetFinder">
            <argument type="service" id="Shopwell\Administration\Snippet\CachedSnippetFinder.inner" />
            <argument type="service" id="cache.object" />
        </service>

        <service id="Shopwell\Administration\Snippet\AppLifecycleSubscriber">
            <argument type="service" id="Shopwell\Core\Framework\App\Source\SourceResolver"/>
            <argument type="service" id="Shopwell\Administration\Snippet\AppAdministrationSnippetPersister"/>

            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Shopwell\Administration\Framework\Routing\KnownIps\KnownIpsCollector"/>

        <service id="Shopwell\Administration\System\SalesChannel\Subscriber\SalesChannelUserConfigSubscriber">
            <argument type="service" id="user_config.repository" />
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Shopwell\Administration\Dashboard\OrderAmountService">
            <argument type="service" id="Doctrine\DBAL\Connection"/>
            <argument type="service" id="Shopwell\Core\Checkout\Cart\Price\CashRounding"/>
            <argument>%shopwell.dbal.time_zone_support_enabled%</argument>
        </service>

        <service id="Shopwell\Administration\Controller\DashboardController" public="true">
            <argument type="service" id="Shopwell\Administration\Dashboard\OrderAmountService"/>
            <call method="setContainer">
                <argument type="service" id="service_container"/>
            </call>
        </service>

        <service id="Shopwell\Administration\Framework\Twig\ViteFileAccessorDecorator" decorates="pentatrion_vite.file_accessor">
            <argument>%pentatrion_vite.configs%</argument>
            <argument type="service" id="shopwell.asset.asset"/>
            <argument type="service" id="kernel"/>
            <argument type="service" id="filesystem"/>
        </service>

        <service id="Shopwell\Administration\Framework\App\Subscriber\SystemLanguageChangedSubscriber">
            <argument type="service" id="locale.repository"/>
            <argument type="service" id="app_administration_snippet.repository"/>

            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Shopwell\Administration\Framework\Adapter\Cache\Http\AdministrationCacheControlListener">
            <tag name="kernel.event_listener" event="Shopwell\Core\Framework\Adapter\Cache\Http\Event\BeforeCacheControlEvent"/>
        </service>
    </services>
</container>
