{
    "name": "shopwell/elasticsearch",
    "description": "Elasticsearch for Shopwell",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Shopwell\\Elasticsearch\\": ""
        }
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "branch-alias": {
            "dev-master": "6.7.x-dev",
            "dev-trunk": "6.7.x-dev"
        }
    },
    "minimum-stability": "stable",
    "require": {
        "php": "~8.2.0 || ~8.3.0 || ~8.4.0 || ~8.5.0",
        "ext-curl": "*",
        "async-aws/core": "^1.22",
        "doctrine/dbal": "~4.4.0",
        "monolog/monolog": "^3.3.1",
        "opensearch-project/opensearch-php": "^2.3.1",
        "shopwell/core": "*",
        "shyim/opensearch-php-dsl": "^1.0.5",
        "symfony/http-foundation": "~7.4.0",
        "symfony/messenger": "~7.4.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5.19"
    }
}
