<?xml version="1.0" ?>
<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">
    <services>
        <service id="Shopwell\Core\Framework\Feature\FeatureFlagRegistry" public="true">
            <argument type="service" id="Shopwell\Core\Framework\Adapter\Storage\AbstractKeyValueStorage"/>
            <argument type="service" id="event_dispatcher" />
            <argument>%shopwell.feature.flags%</argument>
            <argument>%shopwell.feature_toggle.enable%</argument>
        </service>

    </services>
</container>
