<?xml version="1.0" ?>

<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xmlns:monolog="http://symfony.com/schema/dic/monolog"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd http://symfony.com/schema/dic/monolog http://symfony.com/schema/dic/monolog/monolog-1.0.xsd">

    <parameters>
        <parameter key="shopwell.slug.config" type="collection">
            <parameter key="regexp">/([^A-Za-z0-9\.]|-)+/</parameter>
            <parameter key="lowercase">false</parameter>
        </parameter>

        <!-- Populated by RouteScopeCompilerPass with all route prefixes from the registers RouteScopes -->
        <parameter key="shopwell.routing.registered_api_prefixes" type="collection"/>

        <!-- Migration config -->
        <parameter key="core.migration.directories" type="collection"/>

        <parameter key="shopwell.security.csp_templates" type="collection">
            <parameter key="default">
object-src 'none';
script-src 'none';
base-uri 'self';
frame-ancestors 'none';
            </parameter>
            <parameter key="administration">
object-src 'none';
script-src 'strict-dynamic' 'nonce-%%nonce%%' 'unsafe-inline' 'unsafe-eval' https: http:;
base-uri 'self';
frame-ancestors 'none';
            </parameter>
            <parameter key="storefront"/>
            <parameter key="installer"/>
        </parameter>

        <parameter key="shopwell_http_cache_enabled_default">1</parameter>
        <parameter key="shopwell.http.cache.enabled">%env(default:shopwell_http_cache_enabled_default:SHOPWELL_HTTP_CACHE_ENABLED)%</parameter>

        <!-- @deprecated tag:v6.8.0 Will be removed -->
        <parameter key="shopwell_http_cache_default_ttl_default">7200</parameter>
        <!-- @deprecated tag:v6.8.0 Will be removed -->
        <parameter key="shopwell.http.cache.default_ttl">%env(default:shopwell_http_cache_default_ttl_default:SHOPWELL_HTTP_DEFAULT_TTL)%</parameter>
    </parameters>

    <monolog:config>
        <monolog:channel>business_events</monolog:channel>

        <monolog:handler
            name="business_event_handler_buffer"
            type="buffer"
            handler="business_event_handler">
            <monolog:channels>
                <monolog:channel>business_events</monolog:channel>
            </monolog:channels>
        </monolog:handler>

        <monolog:handler
            name="business_event_handler"
            type="service"
            id="Shopwell\Core\Framework\Log\Monolog\DoctrineSQLHandler">
            <monolog:channels>
                <monolog:channel>business_events</monolog:channel>
            </monolog:channels>
        </monolog:handler>
    </monolog:config>

    <services>
        <!-- Database / Doctrine -->
        <service id="Doctrine\DBAL\Connection" public="true">
            <factory class="Shopwell\Core\Kernel" method="getConnection"/>
        </service>

        <service id="Shopwell\Core\Framework\Routing\QueryDataBagResolver">
            <tag name="controller.argument_value_resolver" priority="1000"/>
        </service>

        <service id="Shopwell\Core\Framework\Routing\RequestDataBagResolver">
            <tag name="controller.argument_value_resolver" priority="1000"/>
        </service>

        <!-- Cache -->
        <service class="Cocur\Slugify\Slugify" public="false" id="slugify">
            <argument>%shopwell.slug.config%</argument>
        </service>

        <!-- Migration -->
        <service id="Shopwell\Core\Framework\Migration\MigrationSource.core"
                 class="Shopwell\Core\Framework\Migration\MigrationSource">
            <argument type="string">core</argument>
            <tag name="shopwell.migration_source"/>
        </service>

        <service id="Shopwell\Core\Framework\Migration\MigrationSource.core.V6_3"
                 class="Shopwell\Core\Framework\Migration\MigrationSource">
            <argument type="string">core.V6_3</argument>

            <tag name="shopwell.migration_source"/>
        </service>

        <service id="Shopwell\Core\Framework\Migration\MigrationSource.core.V6_4"
                 class="Shopwell\Core\Framework\Migration\MigrationSource">
            <argument type="string">core.V6_4</argument>
            <tag name="shopwell.migration_source"/>
        </service>

        <service id="Shopwell\Core\Framework\Migration\MigrationSource.core.V6_5"
                 class="Shopwell\Core\Framework\Migration\MigrationSource">
            <argument type="string">core.V6_5</argument>
            <tag name="shopwell.migration_source"/>
        </service>

        <service id="Shopwell\Core\Framework\Migration\MigrationSource.core.V6_6"
                 class="Shopwell\Core\Framework\Migration\MigrationSource">
            <argument type="string">core.V6_6</argument>
            <tag name="shopwell.migration_source"/>
        </service>

        <service id="Shopwell\Core\Framework\Migration\MigrationSource.core.V6_7"
                 class="Shopwell\Core\Framework\Migration\MigrationSource">
            <argument type="string">core.V6_7</argument>
            <tag name="shopwell.migration_source"/>
        </service>

        <service id="Shopwell\Core\Framework\Migration\MigrationSource.core.V6_8"
                 class="Shopwell\Core\Framework\Migration\MigrationSource">
            <argument type="string">core.V6_8</argument>
            <tag name="shopwell.migration_source"/>
        </service>

        <service id="Shopwell\Core\Framework\Migration\MigrationSource.null"
                 class="Shopwell\Core\Framework\Migration\MigrationSource">
            <argument type="string">null</argument>
            <argument type="collection"/>

            <tag name="shopwell.migration_source"/>
        </service>

        <service id="Shopwell\Core\Framework\Migration\MigrationRuntime">
            <argument type="service" id="Doctrine\DBAL\Connection"/>
            <argument type="service" id="logger"/>
        </service>

        <service id="Shopwell\Core\Framework\Migration\MigrationCollectionLoader" public="true">
            <argument type="service" id="Doctrine\DBAL\Connection"/>
            <argument type="service" id="Shopwell\Core\Framework\Migration\MigrationRuntime"/>
            <argument type="service" id="logger"/>
            <argument type="tagged_iterator" tag="shopwell.migration_source"/>
        </service>

        <service id="Shopwell\Core\Framework\Migration\MigrationInfo">
            <argument type="service" id="Doctrine\DBAL\Connection"/>
        </service>

        <service id="Shopwell\Core\Framework\Migration\Command\CreateMigrationCommand">
            <argument type="service" id="Shopwell\Core\Framework\Plugin\KernelPluginCollection"/>
            <argument>%kernel.shopwell_core_dir%</argument>
            <argument>%kernel.shopwell_version%</argument>
            <tag name="console.command"/>
        </service>

        <service id="Shopwell\Core\Framework\Migration\Command\RefreshMigrationCommand">
            <tag name="console.command"/>
        </service>

        <service id="Shopwell\Core\Framework\Migration\Command\MigrationCommand">
            <argument type="service" id="Shopwell\Core\Framework\Migration\MigrationCollectionLoader"/>
            <argument type="service" id="cache.object"/>
            <argument type="string">%kernel.shopwell_version%</argument>

            <tag name="console.command"/>
        </service>

        <service id="Shopwell\Core\Framework\Demodata\PersonalData\CleanPersonalDataCommand">
            <argument type="service" id="Doctrine\DBAL\Connection"/>
            <argument type="service" id="customer.repository"/>

            <tag name="console.command"/>
        </service>

        <service id="Shopwell\Core\Framework\Migration\Command\MigrationDestructiveCommand">
            <argument type="service" id="Shopwell\Core\Framework\Migration\MigrationCollectionLoader"/>
            <argument type="service" id="cache.object"/>
            <argument type="string">%kernel.shopwell_version%</argument>

            <tag name="console.command"/>
        </service>

        <service id="Shopwell\Core\Framework\Migration\IndexerQueuer" public="true">
            <argument type="service" id="Doctrine\DBAL\Connection"/>
        </service>

        <!-- Serializer -->
        <service id="Shopwell\Core\Framework\Struct\Serializer\StructNormalizer">
            <tag name="serializer.normalizer"/>
        </service>

        <!-- Routing -->
        <service id="Shopwell\Core\Framework\Routing\ContextResolverListener">
            <argument type="service" id="Shopwell\Core\Framework\Routing\ApiRequestContextResolver"/>

            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Shopwell\Core\Framework\Routing\CoreSubscriber">
            <argument>%shopwell.security.csp_templates%</argument>
            <argument type="service" id="Shopwell\Core\Framework\Script\Execution\ScriptExecutor"/>
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Shopwell\Core\Framework\Routing\SymfonyRouteScopeWhitelist">
            <tag name="shopwell.route_scope_whitelist"/>
        </service>

        <service id="Shopwell\Core\Framework\Routing\PaymentScopeWhitelist">
            <tag name="shopwell.route_scope_whitelist"/>
        </service>

        <service id="Shopwell\Core\Framework\Routing\RouteScopeListener">
            <argument type="service" id="Shopwell\Core\Framework\Routing\RouteScopeRegistry"/>
            <argument type="service" id="request_stack"/>
            <argument type="tagged_iterator" tag="shopwell.route_scope_whitelist"/>

            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Shopwell\Core\Framework\Routing\CanonicalRedirectService" public="true">
            <argument type="service" id="Shopwell\Core\System\SystemConfig\SystemConfigService"/>
            <argument type="service" id="Shopwell\Core\Framework\Extensions\ExtensionDispatcher"/>
        </service>

        <service id="Shopwell\Core\Framework\Routing\RouteEventSubscriber">
            <tag name="kernel.event_subscriber"/>
            <argument type="service" id="event_dispatcher"/>
        </service>

        <service id="Shopwell\Core\Framework\Routing\MaintenanceModeResolver">
            <argument type="service" id="event_dispatcher"/>
        </service>

        <service id="Shopwell\Core\Framework\Routing\Validation\RouteBlocklistService">
            <argument type="service" id="router"/>
        </service>

        <service id="Shopwell\Core\Framework\Routing\Validation\Constraint\RouteNotBlockedValidator">
            <argument type="service" id="Shopwell\Core\Framework\Routing\Validation\RouteBlocklistService"/>
            <tag name="validator.constraint_validator"/>
        </service>

        <!-- Custom Entity -->
        <service id="Shopwell\Core\System\CustomEntity\Xml\Config\CustomEntityEnrichmentService">
            <argument type="service" id="Shopwell\Core\System\CustomEntity\Xml\Config\AdminUi\AdminUiXmlSchemaValidator"/>
        </service>

        <service id="Shopwell\Core\System\CustomEntity\CustomEntityLifecycleService">
            <argument type="service" id="Shopwell\Core\System\CustomEntity\Schema\CustomEntityPersister"/>
            <argument type="service" id="Shopwell\Core\System\CustomEntity\Schema\CustomEntitySchemaUpdater"/>
            <argument type="service" id="Shopwell\Core\System\CustomEntity\Xml\Config\CustomEntityEnrichmentService"/>
            <argument type="service" id="Shopwell\Core\System\CustomEntity\Xml\CustomEntityXmlSchemaValidator"/>
            <argument type="service" id="Shopwell\Core\Framework\App\Source\SourceResolver"/>
        </service>

        <!-- Translation -->
        <service id="Shopwell\Core\Framework\Adapter\Translation\Translator" decorates="translator">
            <argument type="service" id="Shopwell\Core\Framework\Adapter\Translation\Translator.inner"/>
            <argument type="service" id="request_stack"/>
            <argument type="service" id="cache.object"/>
            <argument type="service" id="translator.formatter"/>
            <argument>%kernel.environment%</argument>
            <argument type="service" id="Doctrine\DBAL\Connection"/>
            <argument type="service" id="Shopwell\Core\System\Locale\LanguageLocaleCodeProvider"/>
            <argument type="service" id="Shopwell\Core\System\Snippet\SnippetService"/>
            <argument type="service" id="Shopwell\Core\Framework\Adapter\Cache\CacheTagCollector"/>

            <tag name="monolog.logger"/>
        </service>

        <!-- Snippets -->
        <service id="Shopwell\Core\System\Snippet\SnippetService" lazy="true">
            <argument type="service" id="Doctrine\DBAL\Connection"/>
            <argument type="service" id="Shopwell\Core\System\Snippet\Files\SnippetFileCollection"/>
            <argument type="service" id="snippet.repository"/>
            <argument type="service" id="snippet_set.repository"/>
            <argument type="service" id="Shopwell\Core\System\Snippet\Filter\SnippetFilterFactory"/>
            <argument type="service" id="Shopwell\Core\Framework\Extensions\ExtensionDispatcher"/>
            <argument type="service" id="event_dispatcher"/>
            <argument type="service" id="shopwell.filesystem.private"/>
            <argument type="service" id="filesystem"/>
        </service>

        <service id="Shopwell\Core\System\Snippet\Api\SnippetController" public="true">
            <argument type="service" id="Shopwell\Core\System\Snippet\SnippetService"/>
            <argument type="service" id="Shopwell\Core\System\Snippet\Files\SnippetFileCollection"/>
            <call method="setContainer">
                <argument type="service" id="service_container"/>
            </call>
        </service>

        <service id="Shopwell\Core\System\Snippet\Files\SnippetFileLoader">
            <argument type="service" id="Symfony\Component\HttpKernel\KernelInterface"/>
            <argument type="service" id="Doctrine\DBAL\Connection"/>
            <argument type="service" id="Shopwell\Core\System\Snippet\Files\AppSnippetFileLoader"/>
            <argument type="service" id="Shopwell\Core\Framework\App\ActiveAppsLoader"/>
            <argument type="service" id="Shopwell\Core\System\Snippet\Struct\TranslationConfig"/>
            <argument type="service" id="Shopwell\Core\System\Snippet\Service\TranslationLoader"/>
            <argument type="service" id="shopwell.filesystem.private"/>
        </service>

        <service id="Shopwell\Core\System\Snippet\Files\AppSnippetFileLoader">
            <argument>%kernel.project_dir%</argument>
        </service>

        <service id="Shopwell\Core\System\Snippet\Files\SnippetFileCollection" public="true" lazy="true">
            <factory service="Shopwell\Core\System\Snippet\Files\SnippetFileCollectionFactory"
                     method="createSnippetFileCollection"/>
        </service>

        <service id="Shopwell\Core\System\Snippet\Files\SnippetFileCollectionFactory">
            <argument type="service" id="Shopwell\Core\System\Snippet\Files\SnippetFileLoader"/>
        </service>

        <service id="Shopwell\Core\System\Snippet\Filter\SnippetFilterFactory" public="true">
            <argument type="tagged_iterator" tag="shopwell.snippet.filter"/>
        </service>

        <!--SnippetFilters-->
        <service id="Shopwell\Core\System\Snippet\Filter\AuthorFilter">
            <tag name="shopwell.snippet.filter"/>
        </service>

        <service id="Shopwell\Core\System\Snippet\Filter\AddedFilter">
            <tag name="shopwell.snippet.filter"/>
        </service>

        <service id="Shopwell\Core\System\Snippet\Filter\EditedFilter">
            <tag name="shopwell.snippet.filter"/>
        </service>

        <service id="Shopwell\Core\System\Snippet\Filter\EmptySnippetFilter">
            <tag name="shopwell.snippet.filter"/>
        </service>

        <service id="Shopwell\Core\System\Snippet\Filter\NamespaceFilter">
            <tag name="shopwell.snippet.filter"/>
        </service>

        <service id="Shopwell\Core\System\Snippet\Filter\TermFilter">
            <tag name="shopwell.snippet.filter"/>
        </service>

        <service id="Shopwell\Core\System\Snippet\Filter\TranslationKeyFilter">
            <tag name="shopwell.snippet.filter"/>
        </service>

        <!-- Twig -->
        <service id="Shopwell\Core\Framework\Adapter\Twig\TemplateFinder" public="true">
            <argument type="service" id="twig"/>
            <argument type="service" id="twig.loader"/>
            <argument>%twig.cache%</argument>
            <argument type="service"
                      id="Shopwell\Core\Framework\Adapter\Twig\NamespaceHierarchy\NamespaceHierarchyBuilder"/>
            <argument type="service" id="Shopwell\Core\Framework\Adapter\Twig\TemplateScopeDetector"/>

            <tag name="kernel.reset" method="reset"/>
        </service>

        <service id="Shopwell\Core\Framework\Adapter\Twig\SwTwigFunctionResetter" public="true">
            <tag name="kernel.reset" method="reset"/>
        </service>

        <service id="Shopwell\Core\Framework\Adapter\Twig\NamespaceHierarchy\NamespaceHierarchyBuilder">
            <argument type="tagged_iterator" tag="shopwell.twig.hierarchy_builder"/>
        </service>


        <service id="Shopwell\Core\Framework\Adapter\Twig\NamespaceHierarchy\BundleHierarchyBuilder">
            <argument type="service" id="kernel"/>
            <argument type="service" id="Doctrine\DBAL\Connection"/>

            <tag name="shopwell.twig.hierarchy_builder" priority="1000"/>
        </service>

        <service id="Shopwell\Core\Framework\Adapter\Twig\TemplateScopeDetector">
            <argument type="service" id="request_stack"/>
        </service>

        <service id="Shopwell\Core\Framework\Adapter\Twig\Extension\NodeExtension">
            <argument type="service" id="Shopwell\Core\Framework\Adapter\Twig\TemplateFinder"/>
            <argument type="service" id="Shopwell\Core\Framework\Adapter\Twig\TemplateScopeDetector"/>
            <tag name="twig.extension"/>
        </service>

        <service id="Shopwell\Core\Framework\Adapter\Twig\Extension\PhpSyntaxExtension">
            <tag name="twig.extension" />
            <tag name="shopwell.seo_url.twig.extension"/>
            <tag name="shopwell.app_script.twig.extension"/>
        </service>

        <service id="Shopwell\Core\Framework\Adapter\Twig\Extension\FeatureFlagExtension">
            <tag name="twig.extension"/>
        </service>

        <service class="Twig\Extra\Intl\IntlExtension" id="twig.extension.intl">
            <tag name="twig.extension"/>
        </service>

        <service class="Twig\Extra\String\StringExtension" id="twig.extension.string">
            <tag name="twig.extension"/>
        </service>

        <service class="Symfony\Bridge\Twig\Extension\TranslationExtension" id="twig.extension.trans">
            <argument type="service" id="translator"/>
            <tag name="twig.extension"/>
            <tag name="shopwell.app_script.twig.extension"/>
        </service>

        <service id="Shopwell\Core\Framework\Adapter\Twig\Extension\PcreExtension">
            <tag name="twig.extension"/>
            <tag name="shopwell.app_script.twig.extension"/>
        </service>

        <service id="Shopwell\Core\Framework\Adapter\Twig\Extension\InstanceOfExtension">
            <tag name="twig.extension"/>
        </service>

        <service id="Shopwell\Core\Framework\Adapter\Twig\Filter\CurrencyFilter">
            <argument type="service" id="Shopwell\Core\System\Currency\CurrencyFormatter"/>
            <tag name="twig.extension"/>
        </service>

        <service id="Shopwell\Core\Framework\Adapter\Twig\Filter\EmailIdnTwigFilter">
            <tag name="twig.extension"/>
        </service>

        <service id="Shopwell\Core\Framework\Adapter\Twig\Filter\LeadingSpacesFilter" >
            <tag name="twig.extension"/>
        </service>

        <service id="Cocur\Slugify\Bridge\Twig\SlugifyExtension">
            <argument type="service" id="slugify"/>
            <tag name="twig.extension"/>
            <tag name="shopwell.seo_url.twig.extension"/>
        </service>

        <service id="Shopwell\Core\Framework\Adapter\Twig\Filter\ReplaceRecursiveFilter">
            <tag name="twig.extension"/>
            <tag name="shopwell.app_script.twig.extension"/>
        </service>

        <service id="Shopwell\Core\Framework\Adapter\Twig\Extension\ComparisonExtension">
            <tag name="shopwell.app_script.twig.extension"/>
        </service>

        <service id="Shopwell\Core\Framework\Adapter\Twig\BackwardCompatibleIntlExtension">
            <argument type="service" id="twig.extension.intl"/>
            <tag name="twig.extension"/>
        </service>


        <service id="Shopwell\Core\Framework\Adapter\Twig\SecurityExtension">
            <argument>%shopwell.twig.allowed_php_functions%</argument>
            <tag name="twig.extension"/>
            <tag name="shopwell.seo_url.twig.extension"/>
            <tag name="shopwell.app_script.twig.extension"/>
        </service>

        <service id="Shopwell\Core\Framework\Adapter\Twig\Extension\InAppPurchaseExtension">
            <argument type="service" id="Shopwell\Core\Framework\Store\InAppPurchase"/>
            <tag name="twig.extension"/>
        </service>

        <service id="Shopwell\Core\Framework\Adapter\Twig\StringTemplateRenderer">
            <argument type="service" id="twig"/>
            <argument>%shopwell.cache.twig.string_template_renderer_cache_dir%</argument>
        </service>

        <service id="Shopwell\Core\Framework\Adapter\Twig\TemplateIterator"
                 decorates="twig.template_iterator"
                 public="true">
            <argument type="service" id="Shopwell\Core\Framework\Adapter\Twig\TemplateIterator.inner"/>
            <argument>%kernel.bundles%</argument>
        </service>

        <service id="Shopwell\Core\Framework\Adapter\Twig\EntityTemplateLoader">
            <argument type="service" id="Doctrine\DBAL\Connection"/>
            <argument>%kernel.environment%</argument>

            <tag name="twig.loader"/>
            <tag name="kernel.event_subscriber"/>
            <tag name="kernel.reset" method="reset"/>
        </service>

        <service id="Shopwell\Core\Framework\Adapter\Twig\AppTemplateIterator"
                 decorates="twig.template_iterator"
                 public="true">
            <argument type="service" id="Shopwell\Core\Framework\Adapter\Twig\AppTemplateIterator.inner"/>
            <argument type="service" id="app_template.repository"/>
        </service>

        <service id="Shopwell\Core\Framework\Adapter\Twig\TwigVariableParserFactory"/>

        <service id="Shopwell\Core\Framework\Routing\ApiRequestContextResolver">
            <argument type="service" id="Doctrine\DBAL\Connection"/>
            <argument type="service" id="Shopwell\Core\Framework\Routing\RouteScopeRegistry"/>
        </service>

        <service id="Shopwell\Core\Framework\Routing\SalesChannelRequestContextResolver"
                 decorates="Shopwell\Core\Framework\Routing\ApiRequestContextResolver">
            <argument type="service" id="Shopwell\Core\Framework\Routing\SalesChannelRequestContextResolver.inner"/>
            <argument type="service" id="Shopwell\Core\System\SalesChannel\Context\SalesChannelContextService"/>
            <argument type="service" id="event_dispatcher"/>
            <argument type="service" id="Shopwell\Core\Framework\Routing\RouteScopeRegistry"/>
        </service>

        <service id="Shopwell\Core\Checkout\Cart\ApiOrderCartService">
            <argument type="service" id="Shopwell\Core\Checkout\Cart\SalesChannel\CartService"/>
            <argument type="service" id="Shopwell\Core\System\SalesChannel\Context\SalesChannelContextPersister"/>
        </service>

        <service id="Shopwell\Core\Framework\Api\Controller\SalesChannelProxyController" public="true">
            <argument type="service" id="kernel"/>
            <argument type="service" id="sales_channel.repository"/>
            <argument type="service" id="Shopwell\Core\Framework\Validation\DataValidator"/>
            <argument type="service" id="Shopwell\Core\System\SalesChannel\Context\SalesChannelContextPersister"/>
            <argument type="service" id="Shopwell\Core\System\SalesChannel\Context\SalesChannelContextService"/>
            <argument type="service" id="event_dispatcher"/>
            <argument type="service" id="Shopwell\Core\Checkout\Cart\ApiOrderCartService"/>
            <argument type="service" id="Shopwell\Core\Checkout\Cart\SalesChannel\CartOrderRoute"/>
            <argument type="service" id="Shopwell\Core\Checkout\Cart\SalesChannel\CartService"/>
            <argument type="service" id="request_stack"/>
            <argument type="service" id="Shopwell\Core\Checkout\Customer\ImitateCustomerTokenGenerator"/>
            <call method="setContainer">
                <argument type="service" id="service_container"/>
            </call>
        </service>

        <service id="Shopwell\Core\Framework\Routing\RouteScope">
            <tag name="shopwell.route_scope"/>
        </service>

        <service id="Shopwell\Core\Framework\Routing\ApiRouteScope">
            <tag name="shopwell.route_scope"/>
        </service>

        <service id="Shopwell\Core\Framework\Routing\StoreApiRouteScope">
            <tag name="shopwell.route_scope"/>
        </service>

        <service id="Shopwell\Core\Framework\Routing\RouteScopeRegistry">
            <argument type="tagged_iterator" tag="shopwell.route_scope"/>
        </service>

        <!-- Logging -->
        <service id="Shopwell\Core\Framework\Log\LoggingService">
            <argument>%kernel.environment%</argument>
            <tag name="kernel.event_subscriber"/>
            <argument type="service" id="monolog.logger.business_events"/>
        </service>

        <service id="Shopwell\Core\Framework\Log\ExceptionLogger">
            <argument>%kernel.environment%</argument>
            <argument>%shopwell.logger.enforce_throw_exception%</argument>
            <argument type="service" id="logger"/>
        </service>

        <service id="Shopwell\Core\Framework\Log\ScheduledTask\LogCleanupTask">
            <tag name="shopwell.scheduled.task"/>
        </service>

        <service id="Shopwell\Core\Framework\Log\ScheduledTask\LogCleanupTaskHandler">
            <argument type="service" id="scheduled_task.repository"/>
            <argument type="service" id="logger"/>
            <argument type="service" id="Shopwell\Core\System\SystemConfig\SystemConfigService" />
            <argument type="service" id="Doctrine\DBAL\Connection" />

            <tag name="messenger.message_handler"/>
        </service>

        <service id="Shopwell\Core\Framework\Log\Monolog\DoctrineSQLHandler">
            <argument type="service" id="Doctrine\DBAL\Connection"/>
        </service>

        <service id="Shopwell\Core\Framework\Log\LogEntryDefinition">
            <tag name="shopwell.entity.definition"/>
        </service>

        <service id="Shopwell\Core\Framework\Routing\Annotation\CriteriaValueResolver">
            <argument type="service" id="Shopwell\Core\Framework\DataAbstractionLayer\DefinitionInstanceRegistry"/>
            <argument type="service" id="Shopwell\Core\Framework\DataAbstractionLayer\Search\RequestCriteriaBuilder"/>
            <tag name="controller.argument_value_resolver"/>
        </service>

        <service id="Shopwell\Core\Framework\Feature\Command\FeatureDumpCommand">
            <argument type="service" id="kernel"/>

            <tag name="console.command"/>
            <tag name="console.command" command="administration:dump:features"/>
        </service>

        <service id="Shopwell\Core\Framework\Feature\Command\FeatureDisableCommand">
            <argument type="service" id="Shopwell\Core\Framework\Feature\FeatureFlagRegistry"/>
            <argument type="service" id="Shopwell\Core\Framework\Adapter\Cache\CacheClearer"/>

            <tag name="console.command"/>
        </service>

        <service id="Shopwell\Core\Framework\Feature\Command\FeatureEnableCommand">
            <argument type="service" id="Shopwell\Core\Framework\Feature\FeatureFlagRegistry"/>
            <argument type="service" id="Shopwell\Core\Framework\Adapter\Cache\CacheClearer"/>

            <tag name="console.command"/>
        </service>

