<?xml version="1.0" ?>

<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>
        <service id="Shopwell\Core\System\Language\LanguageDefinition">
            <tag name="shopwell.entity.definition"/>
        </service>

        <service id="Shopwell\Core\System\Language\SalesChannel\SalesChannelLanguageDefinition">
            <tag name="shopwell.sales_channel.entity.definition"/>
        </service>

        <service id="Shopwell\Core\System\Language\LanguageValidator">
            <argument type="service" id="Doctrine\DBAL\Connection"/>
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Shopwell\Core\System\Language\LanguageLoader">
            <argument type="service" id="Doctrine\DBAL\Connection"/>
        </service>

        <service id="Shopwell\Core\System\Language\SalesChannelLanguageLoader">
            <argument type="service" id="Doctrine\DBAL\Connection"/>
        </service>

        <service id="Shopwell\Core\System\Language\CachedLanguageLoader" decorates="Shopwell\Core\System\Language\LanguageLoader">
            <argument type="service" id="Shopwell\Core\System\Language\CachedLanguageLoader.inner"/>
            <argument type="service" id="cache.object"/>
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Shopwell\Core\System\Language\TranslationValidator">
            <argument type="service" id="Shopwell\Core\Framework\DataAbstractionLayer\DefinitionInstanceRegistry"/>
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Shopwell\Core\System\Language\LanguageExceptionHandler">
            <tag name="shopwell.dal.exception_handler"/>
        </service>

        <service id="Shopwell\Core\System\Language\SalesChannel\LanguageRoute" public="true">
            <argument type="service" id="sales_channel.language.repository"/>
            <argument type="service" id="Shopwell\Core\Framework\Adapter\Cache\CacheTagCollector"/>
        </service>

        <service id="Shopwell\Core\System\Language\Rule\LanguageRule">
            <tag name="shopwell.rule.definition"/>
        </service>

    </services>
</container>
