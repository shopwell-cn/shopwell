<?xml version="1.0" ?>

<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">
    <services>
        <service id="Shopwell\Core\Profiling\Integration\Stopwatch">
            <argument type="service" id="debug.stopwatch" on-invalid="null"/>

            <tag name="shopwell.profiler" integration="Symfony"/>
        </service>

        <service id="Shopwell\Core\Profiling\Integration\Tideways">
            <tag name="shopwell.profiler" integration="Tideways"/>
        </service>

        <service id="Shopwell\Core\Framework\Adapter\Command\CacheWatchDelayedCommand">
            <tag name="console.command"/>
            <argument type="service" id="event_dispatcher"/>
            <argument type="service" id="service_container"/>
        </service>

        <service id="Shopwell\Core\Profiling\Integration\Datadog">
            <tag name="shopwell.profiler" integration="Datadog"/>
        </service>

        <service id="Shopwell\Core\Profiling\Integration\ServerTiming">
            <tag name="shopwell.profiler" integration="ServerTiming"/>
            <tag name="kernel.event_listener" event="kernel.response" method="onResponseEvent"/>
        </service>

        <service id="Shopwell\Core\Profiling\Profiler" public="true">
            <argument type="tagged_iterator" tag="shopwell.profiler" index-by="integration"/>
            <argument>%shopwell.profiler.integrations%</argument>
        </service>
    </services>
</container>
