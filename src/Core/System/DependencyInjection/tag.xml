<?xml version="1.0" ?>

<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>
        <service id="Shopwell\Core\System\Tag\TagDefinition">
            <tag name="shopwell.entity.definition"/>
        </service>

        <service id="Shopwell\Core\System\Tag\Service\FilterTagIdsService" public="true">
            <argument type="service" id="Shopwell\Core\System\Tag\TagDefinition"/>
            <argument type="service" id="Doctrine\DBAL\Connection"/>
            <argument type="service" id="Shopwell\Core\Framework\DataAbstractionLayer\Dbal\CriteriaQueryBuilder"/>
        </service>
    </services>
</container>
