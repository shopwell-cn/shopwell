<?xml version="1.0" ?>

<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>
        <service id="Shopwell\Core\System\Currency\CurrencyDefinition">
            <tag name="shopwell.entity.definition"/>
        </service>

        <service id="Shopwell\Core\System\Currency\Aggregate\CurrencyCountryRounding\CurrencyCountryRoundingDefinition">
            <tag name="shopwell.entity.definition"/>
        </service>

        <service id="Shopwell\Core\System\Currency\SalesChannel\SalesChannelCurrencyDefinition">
            <tag name="shopwell.sales_channel.entity.definition"/>
        </service>

        <service id="Shopwell\Core\System\Currency\Aggregate\CurrencyTranslation\CurrencyTranslationDefinition">
            <tag name="shopwell.entity.definition"/>
        </service>

        <service id="Shopwell\Core\System\Currency\CurrencyLoadSubscriber">
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Shopwell\Core\System\Currency\CurrencyValidator">
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Shopwell\Core\System\Currency\Rule\CurrencyRule">
            <tag name="shopwell.rule.definition"/>
        </service>

        <service id="Shopwell\Core\System\Currency\CurrencyFormatter" public="true">
            <argument type="service" id="Shopwell\Core\System\Locale\LanguageLocaleCodeProvider"/>

            <tag name="kernel.reset" method="reset"/>
        </service>

        <service id="Shopwell\Core\System\Currency\SalesChannel\CurrencyRoute" public="true">
            <argument type="service" id="sales_channel.currency.repository"/>
            <argument type="service" id="Shopwell\Core\Framework\Adapter\Cache\CacheTagCollector"/>
        </service>
    </services>
</container>
