<?xml version="1.0" ?>

<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>
        <service id="Shopwell\Core\System\Country\CountryDefinition">
            <tag name="shopwell.entity.definition"/>
        </service>

        <service id="Shopwell\Core\System\Country\SalesChannel\SalesChannelCountryDefinition">
            <tag name="shopwell.sales_channel.entity.definition"/>
        </service>

        <service id="Shopwell\Core\System\Country\Aggregate\CountryState\CountryStateDefinition">
            <tag name="shopwell.entity.definition"/>
        </service>

        <service id="Shopwell\Core\System\Country\Aggregate\CountryState\SalesChannel\SalesChannelCountryStateDefinition">
            <tag name="shopwell.sales_channel.entity.definition"/>
        </service>

        <service id="Shopwell\Core\System\Country\Aggregate\CountryStateTranslation\CountryStateTranslationDefinition">
            <tag name="shopwell.entity.definition"/>
        </service>

        <service id="Shopwell\Core\System\Country\Aggregate\CountryTranslation\CountryTranslationDefinition">
            <tag name="shopwell.entity.definition"/>
        </service>

        <service id="Shopwell\Core\System\Country\SalesChannel\CountryRoute" public="true">
            <argument type="service" id="sales_channel.country.repository"/>
            <argument type="service" id="event_dispatcher"/>
            <argument type="service" id="Shopwell\Core\Framework\Adapter\Cache\CacheTagCollector"/>
        </service>

        <service id="Shopwell\Core\System\Country\SalesChannel\CountryStateRoute" public="true">
            <argument type="service" id="country_state.repository"/>
            <argument type="service" id="event_dispatcher"/>
            <argument type="service" id="Shopwell\Core\Framework\Adapter\Cache\CacheTagCollector"/>
        </service>
    </services>
</container>
