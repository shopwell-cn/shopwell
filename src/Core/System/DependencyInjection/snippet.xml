<?xml version="1.0" ?>

<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>
        <service id="Shopwell\Core\System\Snippet\Aggregate\SnippetSet\SnippetSetDefinition">
            <tag name="shopwell.entity.definition"/>
        </service>

        <service id="Shopwell\Core\System\Snippet\SnippetDefinition">
            <tag name="shopwell.entity.definition"/>
        </service>

        <service id="Shopwell\Core\System\Snippet\SnippetValidatorInterface" class="Shopwell\Core\System\Snippet\SnippetValidator">
            <argument type="service" id="Shopwell\Core\System\Snippet\Files\SnippetFileCollection" />
            <argument type="service" id="Shopwell\Core\System\Snippet\SnippetFileHandler" />
            <argument>%kernel.project_dir%/</argument>
        </service>

        <service id="Shopwell\Core\System\Snippet\SnippetValidator">
            <argument type="service" id="Shopwell\Core\System\Snippet\Files\SnippetFileCollection" />
            <argument type="service" id="Shopwell\Core\System\Snippet\SnippetFileHandler" />
            <argument>%kernel.project_dir%/</argument>
        </service>

        <service id="Shopwell\Core\System\Snippet\SnippetFixer">
            <argument type="service" id="Shopwell\Core\System\Snippet\SnippetFileHandler" />
        </service>

        <service id="Shopwell\Core\System\Snippet\Command\ValidateSnippetsCommand">
            <argument type="service" id="Shopwell\Core\System\Snippet\SnippetValidator" />
            <argument type="service" id="Shopwell\Core\System\Snippet\SnippetFixer" />

            <tag name="console.command"/>
        </service>

        <service id="Shopwell\Core\System\Snippet\Command\Util\CountryAgnosticFileLinter">
            <argument type="service" id="Symfony\Component\Filesystem\Filesystem"/>
            <argument type="service" id="plugin.repository"/>
            <argument type="service" id="app.repository"/>
            <argument type="service">
                <service class="Symfony\Component\Finder\Finder"/>
            </argument>
        </service>

        <service id="Shopwell\Core\System\Snippet\Command\LintTranslationFilesCommand">
            <argument type="service" id="Shopwell\Core\System\Snippet\Command\Util\CountryAgnosticFileLinter"/>

            <tag name="console.command"/>
        </service>

        <service id="Shopwell\Core\System\Snippet\Command\InstallTranslationCommand">
            <argument type="service" id="Shopwell\Core\System\Snippet\Service\TranslationLoader"/>
            <argument type="service" id="Shopwell\Core\System\Snippet\Struct\TranslationConfig"/>
            <argument type="service" id="Shopwell\Core\System\Snippet\Service\TranslationMetadataLoader"/>

            <tag name="console.command"/>
        </service>

        <service id="Shopwell\Core\System\Snippet\Command\UpdateTranslationCommand">
            <argument type="service" id="Shopwell\Core\System\Snippet\Service\TranslationLoader"/>
            <argument type="service" id="Shopwell\Core\System\Snippet\Service\TranslationMetadataLoader"/>

            <tag name="console.command"/>
        </service>

        <service id="shopwell.translation.client" class="GuzzleHttp\Client"/>

        <service id="Shopwell\Core\System\Snippet\Service\TranslationConfigLoader">
            <argument type="service" id="filesystem"/>
        </service>

        <service id="Shopwell\Core\System\Snippet\Struct\TranslationConfig" lazy="true" public="true">
            <factory service="Shopwell\Core\System\Snippet\Service\TranslationConfigLoader" method="load"/>
        </service>

        <service id="Shopwell\Core\System\Snippet\Service\TranslationLoader">
            <argument type="service" id="shopwell.filesystem.private"/>
            <argument type="service" id="language.repository"/>
            <argument type="service" id="locale.repository"/>
            <argument type="service" id="snippet_set.repository"/>
            <argument type="service" id="shopwell.translation.client"/>
            <argument type="service" id="Shopwell\Core\System\Snippet\Struct\TranslationConfig"/>
            <argument type="service" id="validator"/>
        </service>

        <service id="Shopwell\Core\System\Snippet\Service\TranslationMetadataLoader">
            <argument type="service" id="Shopwell\Core\System\Snippet\Struct\TranslationConfig"/>
            <argument type="service" id="shopwell.translation.client"/>
            <argument type="service" id="shopwell.filesystem.private"/>
        </service>

        <service id="Shopwell\Core\System\Snippet\SnippetFileHandler">
            <argument type="service" id="filesystem"/>
        </service>

        <service id="Shopwell\Core\System\Snippet\Subscriber\CustomFieldSubscriber">
            <argument type="service" id="Doctrine\DBAL\Connection"/>
            <tag name="kernel.event_subscriber"/>
        </service>
    </services>
</container>
