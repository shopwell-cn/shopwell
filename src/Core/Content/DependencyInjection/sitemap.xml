<?xml version="1.0" ?>

<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">
    <services>
        <service id="Shopwell\Core\Content\Sitemap\Service\SitemapExporter">
            <argument type="tagged_iterator" tag="shopwell.sitemap_url_provider"/>
            <argument type="service" id="cache.system"/>
            <argument>%shopwell.sitemap.batchsize%</argument>
            <argument type="service" id="shopwell.filesystem.sitemap"/>
            <argument type="service" id="Shopwell\Core\Content\Sitemap\Service\SitemapHandleFactoryInterface"/>
            <argument type="service" id="event_dispatcher"/>
            <argument type="service" id="Shopwell\Core\Checkout\Cart\CartRuleLoader"/>
        </service>

        <service id="Shopwell\Core\Content\Sitemap\Service\SitemapLister">
            <argument type="service" id="shopwell.filesystem.sitemap"/>
            <argument type="service" id="shopwell.asset.sitemap"/>
        </service>

        <service id="Shopwell\Core\Content\Sitemap\Service\ConfigHandler">
            <argument type="tagged_iterator" tag="shopwell.sitemap.config_handler"/>
        </service>

        <service id="Shopwell\Core\Content\Sitemap\Service\SitemapHandleFactoryInterface" class="Shopwell\Core\Content\Sitemap\Service\SitemapHandleFactory">
            <argument type="service" id="event_dispatcher"/>
        </service>

        <service id="Shopwell\Core\Content\Sitemap\SalesChannel\SitemapRoute" public="true">
            <argument type="service" id="Shopwell\Core\Content\Sitemap\Service\SitemapLister"/>
            <argument type="service" id="Shopwell\Core\System\SystemConfig\SystemConfigService"/>
            <argument type="service" id="Shopwell\Core\Content\Sitemap\Service\SitemapExporter"/>
            <argument type="service" id="Shopwell\Core\Framework\Adapter\Cache\CacheTagCollector"/>
        </service>

        <service id="Shopwell\Core\Content\Sitemap\SalesChannel\SitemapFileRoute" public="true">
            <argument type="service" id="shopwell.filesystem.sitemap"/>
            <argument type="service" id="Shopwell\Core\Framework\Extensions\ExtensionDispatcher"/>
        </service>

        <!-- UrlProviders -->
        <service id="Shopwell\Core\Content\Sitemap\Provider\HomeUrlProvider">
            <tag name="shopwell.sitemap_url_provider"/>
        </service>

        <service id="Shopwell\Core\Content\Sitemap\Provider\CategoryUrlProvider">
            <argument type="service" id="Shopwell\Core\Content\Sitemap\Service\ConfigHandler"/>
            <argument type="service" id="Doctrine\DBAL\Connection"/>
            <argument type="service" id="Shopwell\Core\Content\Category\CategoryDefinition"/>
            <argument type="service" id="Shopwell\Core\Framework\DataAbstractionLayer\Dbal\Common\IteratorFactory"/>
            <argument type="service" id="router"/>
            <argument type="service" id="event_dispatcher"/>

            <tag name="shopwell.sitemap_url_provider"/>
        </service>

        <service id="Shopwell\Core\Content\Sitemap\Provider\CustomUrlProvider">
            <argument type="service" id="Shopwell\Core\Content\Sitemap\Service\ConfigHandler"/>

            <tag name="shopwell.sitemap_url_provider"/>
        </service>

        <service id="Shopwell\Core\Content\Sitemap\Provider\ProductUrlProvider">
            <argument type="service" id="Shopwell\Core\Content\Sitemap\Service\ConfigHandler"/>
            <argument type="service" id="Doctrine\DBAL\Connection"/>
            <argument type="service" id="Shopwell\Core\Content\Product\ProductDefinition"/>
            <argument type="service" id="Shopwell\Core\Framework\DataAbstractionLayer\Dbal\Common\IteratorFactory"/>
            <argument type="service" id="router"/>
            <argument type="service" id="Shopwell\Core\System\SystemConfig\SystemConfigService"/>
            <argument type="service" id="event_dispatcher"/>

            <tag name="shopwell.sitemap_url_provider"/>
        </service>

        <service id="Shopwell\Core\Content\Sitemap\Provider\LandingPageUrlProvider">
            <argument type="service" id="Shopwell\Core\Content\Sitemap\Service\ConfigHandler"/>
            <argument type="service" id="Doctrine\DBAL\Connection"/>
            <argument type="service" id="router"/>
            <argument type="service" id="event_dispatcher"/>

            <tag name="shopwell.sitemap_url_provider"/>
        </service>

        <!-- Config Handler -->
        <service id="Shopwell\Core\Content\Sitemap\ConfigHandler\File">
            <argument>%shopwell.sitemap%</argument>
            <tag name="shopwell.sitemap.config_handler"/>
        </service>

        <!-- Commands -->
        <service id="Shopwell\Core\Content\Sitemap\Commands\SitemapGenerateCommand">
            <argument type="service" id="sales_channel.repository"/>
            <argument type="service" id="Shopwell\Core\Content\Sitemap\Service\SitemapExporter"/>
            <argument type="service" id="Shopwell\Core\System\SalesChannel\Context\SalesChannelContextFactory"/>
            <argument type="service" id="event_dispatcher"/>

            <tag name="console.command"/>
        </service>

        <!-- scheduled task -->
        <service id="Shopwell\Core\Content\Sitemap\ScheduledTask\SitemapGenerateTask">
            <tag name="shopwell.scheduled.task"/>
        </service>

        <service id="Shopwell\Core\Content\Sitemap\ScheduledTask\SitemapGenerateTaskHandler">
            <argument type="service" id="scheduled_task.repository"/>
            <argument type="service" id="logger"/>
            <argument type="service" id="sales_channel.repository"/>
            <argument type="service" id="Shopwell\Core\System\SystemConfig\SystemConfigService"/>
            <argument type="service" id="messenger.default_bus"/>
            <argument type="service" id="event_dispatcher"/>

            <tag name="messenger.message_handler"/>
        </service>

        <service id="Shopwell\Core\Content\Sitemap\ScheduledTask\SitemapMessageHandler">
            <argument type="service" id="Shopwell\Core\System\SalesChannel\Context\SalesChannelContextFactory"/>
            <argument type="service" id="Shopwell\Core\Content\Sitemap\Service\SitemapExporter"/>
            <argument type="service" id="logger"/>
            <argument type="service" id="Shopwell\Core\System\SystemConfig\SystemConfigService"/>

            <tag name="messenger.message_handler"/>
        </service>
    </services>
</container>
