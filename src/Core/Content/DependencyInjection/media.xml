<?xml version="1.0" ?>

<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">
    <parameters>
        <parameter type="collection" key="shopwell.media.metadata.types">
            <parameter type="string">\Shopwell\Core\Content\Media\Metadata\Type\ImageMetadata</parameter>
            <parameter type="string">\Shopwell\Core\Content\Media\Metadata\Type\DocumentMetadata</parameter>
            <parameter type="string">\Shopwell\Core\Content\Media\Metadata\Type\VideoMetadata</parameter>
        </parameter>
    </parameters>
    <services>
        <!-- region Entity definitions -->
        <service id="Shopwell\Core\Content\Media\MediaDefinition">
            <tag name="shopwell.entity.definition"/>
            <tag name="shopwell.entity.hookable"/>
        </service>

        <service id="Shopwell\Core\Content\Media\Aggregate\MediaDefaultFolder\MediaDefaultFolderDefinition">
            <tag name="shopwell.entity.definition"/>
        </service>

        <service id="Shopwell\Core\Content\Media\Aggregate\MediaThumbnail\MediaThumbnailDefinition">
            <tag name="shopwell.entity.definition"/>
        </service>

        <service id="Shopwell\Core\Content\Media\Aggregate\MediaTranslation\MediaTranslationDefinition">
            <tag name="shopwell.entity.definition"/>
        </service>

        <service id="Shopwell\Core\Content\Media\Aggregate\MediaFolder\MediaFolderDefinition">
            <tag name="shopwell.entity.definition"/>
        </service>

        <service id="Shopwell\Core\Content\Media\Aggregate\MediaThumbnailSize\MediaThumbnailSizeDefinition">
            <tag name="shopwell.entity.definition"/>
        </service>

        <service id="Shopwell\Core\Content\Media\Aggregate\MediaFolderConfiguration\MediaFolderConfigurationDefinition">
            <tag name="shopwell.entity.definition"/>
        </service>

        <service id="Shopwell\Core\Content\Media\Aggregate\MediaFolderConfigurationMediaThumbnailSize\MediaFolderConfigurationMediaThumbnailSizeDefinition">
            <tag name="shopwell.entity.definition"/>
        </service>

        <service id="Shopwell\Core\Content\Media\Aggregate\MediaTag\MediaTagDefinition">
            <tag name="shopwell.entity.definition"/>
        </service>
        <!-- endregion Entity definitions -->

        <!-- region Message handlers -->
        <service id="Shopwell\Core\Content\Media\Message\GenerateThumbnailsHandler">
            <argument type="service" id="Shopwell\Core\Content\Media\Thumbnail\ThumbnailService"/>
            <argument type="service" id="media.repository"/>
            <argument>%shopwell.media.remote_thumbnails.enable%</argument>

            <tag name="messenger.message_handler"/>
        </service>

        <service id="Shopwell\Core\Content\Media\Message\DeleteFileHandler">
            <argument type="service" id="shopwell.filesystem.public"/>
            <argument type="service" id="shopwell.filesystem.private"/>

            <tag name="messenger.message_handler"/>
        </service>

        <service id="Shopwell\Core\Content\Media\ScheduledTask\CleanupCorruptedMediaHandler">
            <argument type="service" id="scheduled_task.repository" />
            <argument type="service" id="logger"/>
            <argument type="service" id="media.repository"/>
            <tag name="messenger.message_handler" />
        </service>
        <!-- endregion Message handlers -->

        <!-- region File Services-->
        <service id="Shopwell\Core\Content\Media\File\FileService">
        </service>

        <service id="Shopwell\Core\Content\Media\File\FileFetcher">
            <argument type="service" id="Shopwell\Core\Content\Media\File\FileUrlValidatorInterface" />
            <argument type="service" id="Shopwell\Core\Content\Media\File\FileService" />
            <argument>%shopwell.media.enable_url_upload_feature%</argument>
            <argument>%shopwell.media.enable_url_validation%</argument>
            <argument>%shopwell.media.url_upload_max_size%</argument>
        </service>

        <service class="Shopwell\Core\Content\Media\File\FileUrlValidator" id="Shopwell\Core\Content\Media\File\FileUrlValidatorInterface">
        </service>

        <service id="Shopwell\Core\Content\Media\File\FileSaver" public="true">
            <argument type="service" id="media.repository"/>
            <argument type="service" id="shopwell.filesystem.public"/>
            <argument type="service" id="shopwell.filesystem.private"/>
            <argument type="service" id="Shopwell\Core\Content\Media\Thumbnail\ThumbnailService"/>
            <argument type="service" id="Shopwell\Core\Content\Media\Metadata\MetadataLoader"/>
            <argument type="service" id="Shopwell\Core\Content\Media\TypeDetector\TypeDetector"/>
            <argument type="service" id="messenger.default_bus" />
            <argument type="service" id="event_dispatcher" />
            <argument type="service" id="Shopwell\Core\Content\Media\Core\Application\MediaLocationBuilder" />
            <argument type="service" id="Shopwell\Core\Content\Media\Core\Application\AbstractMediaPathStrategy" />
            <argument>%shopwell.filesystem.allowed_extensions%</argument>
            <argument>%shopwell.filesystem.private_allowed_extensions%</argument>
            <argument>%shopwell.media.remote_thumbnails.enable%</argument>
        </service>

        <service id="Shopwell\Core\Content\Media\File\FileLoader">
            <argument type="service" id="shopwell.filesystem.public"/>
            <argument type="service" id="shopwell.filesystem.private"/>
            <argument type="service" id="media.repository"/>
            <argument type="service" id="Nyholm\Psr7\Factory\Psr17Factory"/>
        </service>

        <service id="Shopwell\Core\Content\Media\File\FileNameProvider" class="Shopwell\Core\Content\Media\File\WindowsStyleFileNameProvider">
            <argument type="service" id="media.repository"/>
        </service>

        <service id="Shopwell\Core\Content\Media\File\DownloadResponseGenerator">
            <argument type="service" id="logger"/>
            <argument type="service" id="shopwell.filesystem.public"/>
            <argument type="service" id="shopwell.filesystem.private"/>
            <argument type="service" id="Shopwell\Core\Content\Media\MediaService"/>
            <argument>%shopwell.filesystem.private_local_download_strategy%</argument>
            <argument type="service" id="Shopwell\Core\Content\Media\Core\Application\AbstractMediaUrlGenerator"/>
            <argument>%shopwell.filesystem.private_local_path_prefix%</argument>
        </service>
        <!-- endregion File Services-->

        <!-- region Commands -->
        <service id="Shopwell\Core\Content\Media\Commands\GenerateThumbnailsCommand">
            <argument type="service" id="Shopwell\Core\Content\Media\Thumbnail\ThumbnailService"/>
            <argument type="service" id="media.repository"/>
            <argument type="service" id="media_folder.repository"/>
            <argument type="service" id="messenger.default_bus"/>
            <argument>%shopwell.media.remote_thumbnails.enable%</argument>

            <tag name="console.command"/>
        </service>

        <service id="Shopwell\Core\Content\Media\Commands\GenerateMediaTypesCommand">
            <argument type="service" id="Shopwell\Core\Content\Media\TypeDetector\TypeDetector"/>
            <argument type="service" id="media.repository"/>

            <tag name="console.command"/>
        </service>

        <service id="Shopwell\Core\Content\Media\Commands\DeleteNotUsedMediaCommand" shared="false">
            <argument type="service" id="Shopwell\Core\Content\Media\UnusedMediaPurger"/>
            <argument type="service" id="event_dispatcher" />

            <tag name="console.command"/>
        </service>

        <service id="Shopwell\Core\Content\Media\Commands\DeleteThumbnailsCommand">
            <argument type="service" id="Doctrine\DBAL\Connection"/>
            <argument type="service" id="media_thumbnail.repository"/>
            <argument>%shopwell.media.remote_thumbnails.enable%</argument>

            <tag name="console.command"/>
        </service>
        <!-- endregion Commands -->

        <!-- region Controller -->
        <service id="Shopwell\Core\Content\Media\Api\MediaUploadController" public="true">
            <argument type="service" id="Shopwell\Core\Content\Media\MediaService"/>
            <argument type="service" id="Shopwell\Core\Content\Media\File\FileSaver"/>
            <argument type="service" id="Shopwell\Core\Content\Media\File\FileNameProvider"/>
            <argument type="service" id="Shopwell\Core\Content\Media\MediaDefinition"/>
            <argument type="service" id="event_dispatcher"/>

            <call method="setContainer">
                <argument type="service" id="service_container"/>
            </call>
        </service>

        <service id="Shopwell\Core\Content\Media\Api\MediaFolderController" public="true">
            <argument type="service" id="Shopwell\Core\Content\Media\MediaFolderService"/>
            <call method="setContainer">
                <argument type="service" id="service_container"/>
            </call>
        </service>

        <service id="Shopwell\Core\Content\Media\Api\MediaUploadV2Controller" public="true">
            <argument type="service" id="Shopwell\Core\Content\Media\Upload\MediaUploadService"/>
            <argument type="service" id="media.repository"/>
        </service>

        <service id="Shopwell\Core\Content\Media\Api\MediaVideoCoverController" public="true">
            <argument type="service" id="Shopwell\Core\Content\Media\Service\VideoCoverService"/>
            <tag name="controller.service_arguments"/>
            <call method="setContainer">
                <argument type="service" id="service_container"/>
            </call>
        </service>
        <!-- endregion Controller -->

        <!-- region Normalizers -->
        <service id="Shopwell\Core\Content\Media\Thumbnail\ExternalThumbnailCollectionNormalizer">
            <tag name="serializer.normalizer"/>
        </service>

        <service id="Shopwell\Core\Content\Media\Thumbnail\ExternalThumbnailDataNormalizer">
            <tag name="serializer.normalizer"/>
        </service>
        <!-- endregion Normalizers -->

        <!-- region Metadata -->
        <service id="Shopwell\Core\Content\Media\Metadata\MetadataLoader\ImageMetadataLoader">
            <tag name="shopwell.metadata.loader"/>
        </service>

        <service id="Shopwell\Core\Content\Media\Metadata\MetadataLoader">
            <argument type="tagged_iterator" tag="shopwell.metadata.loader"/>
        </service>
        <!-- endregion Metadata -->

        <!-- region TypeDetector -->
        <service id="Shopwell\Core\Content\Media\TypeDetector\AudioTypeDetector">
            <tag name="shopwell.media_type.detector" priority="10"/>
        </service>

        <service id="Shopwell\Core\Content\Media\TypeDetector\DefaultTypeDetector">
            <tag name="shopwell.media_type.detector" priority="0"/>
        </service>

        <service id="Shopwell\Core\Content\Media\TypeDetector\DocumentTypeDetector">
            <tag name="shopwell.media_type.detector" priority="10"/>
        </service>

        <service id="Shopwell\Core\Content\Media\TypeDetector\ImageTypeDetector">
            <tag name="shopwell.media_type.detector" priority="10"/>
        </service>

        <service id="Shopwell\Core\Content\Media\TypeDetector\VideoTypeDetector">
            <tag name="shopwell.media_type.detector" priority="10"/>
        </service>

        <service id="Shopwell\Core\Content\Media\TypeDetector\SpatialObjectTypeDetector">
            <tag name="shopwell.media_type.detector" priority="10"/>
        </service>

        <service id="Shopwell\Core\Content\Media\TypeDetector\TypeDetector">
            <argument type="tagged_iterator" tag="shopwell.media_type.detector"/>
        </service>
        <!-- endregion TypeDetector -->

        <!-- region Services -->
        <service id="Shopwell\Core\Content\Media\UnusedMediaPurger">
            <argument type="service" id="media.repository"/>
            <argument type="service" id="Doctrine\DBAL\Connection" />
            <argument type="service" id="event_dispatcher"/>
        </service>

        <service id="Shopwell\Core\Content\Media\MediaFolderService">
            <argument type="service" id="media.repository"/>
            <argument type="service" id="media_folder.repository"/>
            <argument type="service" id="media_folder_configuration.repository"/>
        </service>

        <service id="Shopwell\Core\Content\Media\Thumbnail\ThumbnailService">
            <argument type="service" id="media_thumbnail.repository"/>
            <argument type="service" id="shopwell.filesystem.public"/>
            <argument type="service" id="shopwell.filesystem.private"/>
            <argument type="service" id="media_folder.repository"/>
            <argument type="service" id="event_dispatcher"/>
            <argument type="service" id="Shopwell\Core\Content\Media\DataAbstractionLayer\MediaIndexer"/>
            <argument type="service" id="Shopwell\Core\Content\Media\Thumbnail\ThumbnailSizeCalculator"/>
            <argument type="service" id="Doctrine\DBAL\Connection"/>
            <argument>%shopwell.media.remote_thumbnails.enable%</argument>
        </service>

        <service id="Shopwell\Core\Content\Media\MediaService">
            <argument type="service" id="media.repository"/>
            <argument type="service" id="media_folder.repository"/>
            <argument type="service" id="Shopwell\Core\Content\Media\File\FileLoader"/>
            <argument type="service" id="Shopwell\Core\Content\Media\File\FileSaver"/>
            <argument type="service" id="Shopwell\Core\Content\Media\File\FileFetcher"/>
        </service>

        <service id="Shopwell\Core\Content\Media\Upload\MediaUploadService">
            <argument type="service" id="media.repository"/>
            <argument type="service" id="Shopwell\Core\Content\Media\File\FileFetcher"/>
            <argument type="service" id="Shopwell\Core\Content\Media\File\FileSaver"/>
            <argument type="service" id="event_dispatcher"/>
            <argument type="service" id="shopwell.media.upload.http_client"/>
            <argument type="service" id="media_thumbnail.repository"/>
            <argument type="service" id="media_thumbnail_size.repository"/>
        </service>

        <service id="Shopwell\Core\Content\Media\Service\VideoCoverService">
            <argument type="service" id="media.repository"/>
        </service>

        <service id="Shopwell\Core\Content\Media\Thumbnail\ThumbnailSizeCalculator">
        </service>
        <!-- endregion Services -->

        <!-- region Testable service aliases -->
        <service id="shopwell.media.upload.http_client" alias="http_client" public="false"/>
        <!-- endregion Testable service aliases -->

        <service id="Shopwell\Core\Content\Media\Upload\PresignedUploadUrlGenerator">
            <factory class="Shopwell\Core\Content\Media\Upload\PresignedUploadUrlGenerator" method="create"/>
            <argument type="service" id="Shopwell\Core\Content\Media\Core\Application\AbstractMediaPathStrategy"/>
            <argument>%shopwell.filesystem.public%</argument>
            <argument type="service" id="logger"/>
        </service>

        <service id="Shopwell\Core\Content\Media\MediaUrlPlaceholderHandlerInterface" class="Shopwell\Core\Content\Media\MediaUrlPlaceholderHandler" public="true">
            <argument type="service" id="Doctrine\DBAL\Connection"/>
            <argument type="service" id="Shopwell\Core\Content\Media\Core\Application\AbstractMediaUrlGenerator"/>
        </service>

        <!-- region DBAL -->
        <service id="Shopwell\Core\Content\Media\DataAbstractionLayer\MediaIndexer">
            <tag name="shopwell.entity_indexer"/>
            <argument type="service" id="Shopwell\Core\Framework\DataAbstractionLayer\Dbal\Common\IteratorFactory"/>
            <argument type="service" id="media.repository"/>
            <argument type="service" id="media_thumbnail.repository"/>
            <argument type="service" id="Doctrine\DBAL\Connection"/>
            <argument type="service" id="event_dispatcher"/>
            <argument>%shopwell.media.remote_thumbnails.enable%</argument>
        </service>

        <service id="Shopwell\Core\Content\Media\DataAbstractionLayer\MediaFolderConfigurationIndexer">
            <tag name="shopwell.entity_indexer"/>
            <argument type="service" id="Shopwell\Core\Framework\DataAbstractionLayer\Dbal\Common\IteratorFactory"/>
            <argument type="service" id="media_folder_configuration.repository"/>
            <argument type="service" id="Doctrine\DBAL\Connection"/>
            <argument type="service" id="event_dispatcher"/>
        </service>

        <service id="Shopwell\Core\Content\Media\DataAbstractionLayer\MediaFolderIndexer">
            <argument type="service" id="Shopwell\Core\Framework\DataAbstractionLayer\Dbal\Common\IteratorFactory"/>
            <argument type="service" id="media_folder.repository"/>
            <argument type="service" id="Doctrine\DBAL\Connection"/>
            <argument type="service" id="event_dispatcher"/>
            <argument type="service" id="Shopwell\Core\Framework\DataAbstractionLayer\Indexing\ChildCountUpdater"/>
            <argument type="service" id="Shopwell\Core\Framework\DataAbstractionLayer\Indexing\TreeUpdater"/>

            <tag name="shopwell.entity_indexer"/>
        </service>
        <!-- endregion DBAL -->

        <!-- region Event handling -->
        <service id="Shopwell\Core\Content\Media\Subscriber\MediaFolderConfigLoadedSubscriber">
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Shopwell\Core\Content\Media\Subscriber\MediaDeletionSubscriber">
            <argument type="service" id="event_dispatcher"/>
            <argument type="service" id="media_thumbnail.repository"/>
            <argument type="service" id="messenger.default_bus"/>
            <argument type="service" id="Shopwell\Core\Content\Media\Message\DeleteFileHandler"/>
            <argument type="service" id="Doctrine\DBAL\Connection"/>
            <argument type="service" id="media.repository"/>

            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Shopwell\Core\Content\Media\Subscriber\MediaVisibilityRestrictionSubscriber">
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Shopwell\Core\Content\Media\Subscriber\MediaCreationSubscriber">
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Shopwell\Core\Content\Media\Subscriber\CustomFieldsUnusedMediaSubscriber">
            <argument type="service" id="Doctrine\DBAL\Connection"/>
            <argument type="service" id="Shopwell\Core\Framework\DataAbstractionLayer\DefinitionInstanceRegistry"/>

            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Shopwell\Core\Content\Media\Subscriber\VideoCoverLoadedSubscriber">
            <argument type="service" id="media.repository"/>

            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Shopwell\Core\Content\Media\Subscriber\VideoCoverCleanupSubscriber">
            <argument type="service" id="media.repository"/>

            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Shopwell\Core\Content\Media\Subscriber\MediaLoadedSubscriber">
            <!-- unseralize read optimized (serialized) database objects > restores thumbnails from `RO` into real property-->
            <tag name="kernel.event_listener" event="media.loaded" method="unserialize" priority="100" />
        </service>
        <!-- endregion Event handling -->

        <!-- region Routes -->
        <service id="Shopwell\Core\Content\Media\SalesChannel\MediaRoute" public="true">
            <argument type="service" id="media.repository"/>
            <argument type="service" id="Shopwell\Core\Framework\Adapter\Cache\CacheTagCollector"/>
        </service>
        <!-- endregion Routes -->

        <!-- region Tasks -->
        <service id="Shopwell\Core\Content\Media\ScheduledTask\CleanupCorruptedMediaTask">
            <tag name="shopwell.scheduled.task"/>
        </service>
        <!-- endregion Tasks -->

    </services>
</container>
