<?xml version="1.0" ?>

<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">
    <services>
        <service id="Shopwell\Core\Content\Rule\RuleDefinition">
            <tag name="shopwell.entity.definition"/>
        </service>
        <service id="Shopwell\Core\Content\Rule\Aggregate\RuleCondition\RuleConditionDefinition">
            <tag name="shopwell.entity.definition"/>
        </service>
        <service id="Shopwell\Core\Content\Rule\Aggregate\RuleTag\RuleTagDefinition">
            <tag name="shopwell.entity.definition"/>
        </service>

        <service id="Shopwell\Core\Content\Rule\RuleValidator">
            <argument type="service" id="validator"/>
            <argument type="service" id="Shopwell\Core\Framework\Rule\Collector\RuleConditionRegistry"/>
            <argument type="service" id="rule_condition.repository" />
            <argument type="service" id="app_script_condition.repository" />

            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Shopwell\Core\Content\Rule\DataAbstractionLayer\RulePayloadSubscriber">
            <tag name="kernel.event_subscriber"/>
            <argument type="service" id="Shopwell\Core\Content\Rule\DataAbstractionLayer\RulePayloadUpdater"/>
            <argument type="service" id="service_container"/>
        </service>

        <service id="Shopwell\Core\Content\Rule\DataAbstractionLayer\RuleIndexer">
            <argument type="service" id="Shopwell\Core\Framework\DataAbstractionLayer\Dbal\Common\IteratorFactory"/>
            <argument type="service" id="rule.repository"/>
            <argument type="service" id="Shopwell\Core\Content\Rule\DataAbstractionLayer\RulePayloadUpdater"/>
            <argument type="service" id="Shopwell\Core\Content\Rule\DataAbstractionLayer\RuleAreaUpdater"/>
            <argument type="service" id="event_dispatcher"/>
            <tag name="shopwell.entity_indexer"/>
        </service>

        <service id="Shopwell\Core\Content\Rule\DataAbstractionLayer\RuleIndexerSubscriber">
            <tag name="kernel.event_subscriber"/>
            <argument type="service" id="Doctrine\DBAL\Connection"/>
            <argument type="service" id="Shopwell\Core\Checkout\Cart\CartRuleLoader"/>
            <argument type="service" id="Symfony\Component\Clock\ClockInterface"/>
        </service>


        <service id="Shopwell\Core\Content\Rule\DataAbstractionLayer\RulePayloadUpdater">
            <argument type="service" id="Doctrine\DBAL\Connection"/>
            <argument type="service" id="Shopwell\Core\Framework\Rule\Collector\RuleConditionRegistry"/>
            <argument type="service" id="Symfony\Component\Clock\ClockInterface"/>
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Shopwell\Core\Content\Rule\DataAbstractionLayer\RuleAreaUpdater">
            <argument type="service" id="Doctrine\DBAL\Connection"/>
            <argument type="service" id="Shopwell\Core\Content\Rule\RuleDefinition"/>
            <argument type="service" id="Shopwell\Core\Framework\Rule\Collector\RuleConditionRegistry"/>
            <argument type="service" id="Shopwell\Core\Framework\Adapter\Cache\CacheInvalidator"/>
            <argument type="service" id="Shopwell\Core\Framework\DataAbstractionLayer\DefinitionInstanceRegistry"/>
            <argument type="service" id="Symfony\Component\Clock\ClockInterface"/>
            <tag name="kernel.event_subscriber"/>
        </service>
    </services>
</container>
