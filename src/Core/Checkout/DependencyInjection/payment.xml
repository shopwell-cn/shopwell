<?xml version="1.0" ?>

<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>
        <service id="Shopwell\Core\Checkout\Payment\PaymentMethodDefinition">
            <tag name="shopwell.entity.definition"/>
        </service>

        <service id="Shopwell\Core\Checkout\Payment\SalesChannel\SalesChannelPaymentMethodDefinition">
            <tag name="shopwell.sales_channel.entity.definition"/>
        </service>

        <service id="Shopwell\Core\Checkout\Payment\Aggregate\PaymentMethodTranslation\PaymentMethodTranslationDefinition">
            <tag name="shopwell.entity.definition"/>
        </service>

        <service id="Shopwell\Core\Checkout\Payment\DataAbstractionLayer\PaymentMethodValidator">
            <argument type="service" id="Doctrine\DBAL\Connection"/>

            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Shopwell\Core\Checkout\Payment\PaymentProcessor">
            <argument type="service" id="Shopwell\Core\Checkout\Payment\Cart\Token\JWTFactoryV2" on-invalid="null"/>
            <argument type="service" id="Shopwell\Core\Checkout\Payment\Cart\Token\PaymentTokenGenerator"/>
            <argument type="service" id="Shopwell\Core\Checkout\Payment\Cart\Token\PaymentTokenLifecycle"/>
            <argument type="service" id="Shopwell\Core\Checkout\Payment\Cart\PaymentHandler\PaymentHandlerRegistry"/>
            <argument type="service" id="order_transaction.repository"/>
            <argument type="service" id="Shopwell\Core\Checkout\Order\Aggregate\OrderTransaction\OrderTransactionStateHandler"/>
            <argument type="service" id="logger"/>
            <argument type="service" id="Shopwell\Core\Checkout\Payment\Cart\PaymentTransactionStructFactory"/>
            <argument type="service" id="Shopwell\Core\System\StateMachine\Loader\InitialStateIdLoader"/>
            <argument type="service" id="router"/>
            <argument type="service" id="Shopwell\Core\System\SystemConfig\SystemConfigService"/>
        </service>

        <service id="Shopwell\Core\Checkout\Payment\Controller\PaymentController" public="true">
            <argument type="service" id="Shopwell\Core\Checkout\Payment\PaymentProcessor"/>
            <argument type="service" id="Shopwell\Core\Checkout\Cart\Order\OrderConverter"/>
            <argument type="service" id="Shopwell\Core\Checkout\Payment\Cart\Token\PaymentTokenGenerator"/>
            <argument type="service" id="Shopwell\Core\Checkout\Payment\Cart\Token\PaymentTokenLifecycle"/>
            <argument type="service" id="order.repository"/>
            <call method="setContainer">
                <argument type="service" id="service_container"/>
            </call>
        </service>

        <service id="Shopwell\Core\Checkout\Payment\Cart\PaymentTransactionStructFactory"/>

        <service id="Shopwell\Core\Checkout\Payment\Cart\PaymentRefundProcessor" public="true">
            <argument type="service" id="Doctrine\DBAL\Connection"/>
            <argument type="service" id="Shopwell\Core\Checkout\Order\Aggregate\OrderTransactionCaptureRefund\OrderTransactionCaptureRefundStateHandler"/>
            <argument type="service" id="Shopwell\Core\Checkout\Payment\Cart\PaymentHandler\PaymentHandlerRegistry"/>
            <argument type="service" id="Shopwell\Core\Checkout\Payment\Cart\PaymentTransactionStructFactory"/>
        </service>

        <service id="Shopwell\Core\Checkout\Payment\Cart\PaymentRecurringProcessor" public="true">
            <argument type="service" id="order_transaction.repository"/>
            <argument type="service" id="Shopwell\Core\System\StateMachine\Loader\InitialStateIdLoader"/>
            <argument type="service" id="Shopwell\Core\Checkout\Order\Aggregate\OrderTransaction\OrderTransactionStateHandler"/>
            <argument type="service" id="Shopwell\Core\Checkout\Payment\Cart\PaymentHandler\PaymentHandlerRegistry"/>
            <argument type="service" id="Shopwell\Core\Checkout\Payment\Cart\PaymentTransactionStructFactory"/>
            <argument type="service" id="logger"/>
        </service>

        <service id="Shopwell\Core\Checkout\Payment\Cart\Token\JWTFactoryV2">
            <argument type="service" id="shopwell.jwt_config"/>
            <argument type="service" id="Doctrine\DBAL\Connection"/>

            <deprecated package="shopwell/core" version="6.8.0.0">tag:v6.8.0 - The %service_id% service will be removed in v6.8.0.0. Use Shopwell\Core\Checkout\Payment\Cart\Token\PaymentTokenGenerator instead.</deprecated>
        </service>

        <service id="Shopwell\Core\Checkout\Payment\Cart\Token\Constraint\PaymentTokenRegisteredValidator">
            <argument type="service" id="Shopwell\Core\Checkout\Payment\Cart\Token\PaymentTokenLifecycle"/>

            <tag name="validator.constraint_validator"/>
        </service>

        <service id="Shopwell\Core\Checkout\Payment\Cart\Token\PaymentTokenGenerator">
            <argument type="service" id="shopwell.jwt_config"/>
            <argument type="service" id="Shopwell\Core\Framework\Validation\DataValidator"/>
            <argument type="service" id="Shopwell\Core\System\SystemConfig\SystemConfigService"/>
        </service>

        <service id="Shopwell\Core\Checkout\Payment\Cart\Token\PaymentTokenLifecycle">
            <argument type="service" id="Doctrine\DBAL\Connection"/>
        </service>

        <service id="Shopwell\Core\Checkout\Payment\Cart\PaymentHandler\PaymentHandlerRegistry">
            <argument type="tagged_locator" tag="shopwell.payment.method"/>
            <argument type="service" id="Doctrine\DBAL\Connection"/>
        </service>

        <service id="Shopwell\Core\Checkout\Payment\Cart\PaymentHandler\PrePayment">
            <argument type="service" id="Shopwell\Core\Checkout\Order\Aggregate\OrderTransaction\OrderTransactionStateHandler"/>

            <tag name="shopwell.payment.method"/>
        </service>

        <service id="Shopwell\Core\Checkout\Payment\Cart\PaymentHandler\CashPayment">
            <argument type="service" id="Shopwell\Core\Checkout\Order\Aggregate\OrderTransaction\OrderTransactionStateHandler"/>

            <tag name="shopwell.payment.method"/>
        </service>

        <service id="Shopwell\Core\Checkout\Payment\Cart\PaymentHandler\InvoicePayment">
            <argument type="service" id="Shopwell\Core\Checkout\Order\Aggregate\OrderTransaction\OrderTransactionStateHandler"/>

            <tag name="shopwell.payment.method"/>
        </service>

        <service id="Shopwell\Core\Checkout\Payment\Cart\PaymentHandler\DefaultPayment">
            <argument type="service" id="Shopwell\Core\Checkout\Order\Aggregate\OrderTransaction\OrderTransactionStateHandler"/>

            <tag name="shopwell.payment.method"/>
        </service>

        <service id="Shopwell\Core\Checkout\Payment\DataAbstractionLayer\PaymentHandlerIdentifierSubscriber">
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Shopwell\Core\Checkout\Payment\DataAbstractionLayer\PaymentDistinguishableNameSubscriber">
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Shopwell\Core\Checkout\Payment\DataAbstractionLayer\PaymentMethodIndexer">
            <argument type="service" id="Shopwell\Core\Framework\DataAbstractionLayer\Dbal\Common\IteratorFactory"/>
            <argument type="service" id="event_dispatcher"/>
            <argument type="service" id="payment_method.repository"/>
            <argument type="service" id="Shopwell\Core\Checkout\Payment\DataAbstractionLayer\PaymentDistinguishableNameGenerator"/>

            <tag name="shopwell.entity_indexer"/>
        </service>

        <service id="Shopwell\Core\Checkout\Payment\DataAbstractionLayer\PaymentDistinguishableNameGenerator">
            <argument type="service" id="payment_method.repository"/>
        </service>

        <service id="Shopwell\Core\Checkout\Payment\Cart\PaymentMethodValidator">
            <tag name="shopwell.cart.validator"/>
        </service>

        <service id="Shopwell\Core\Checkout\Payment\Cleanup\CleanupPaymentTokenTask">
            <tag name="shopwell.scheduled.task"/>
        </service>

        <service id="Shopwell\Core\Checkout\Payment\Cleanup\CleanupPaymentTokenTaskHandler">
            <argument type="service" id="scheduled_task.repository"/>
            <argument type="service" id="logger"/>
            <argument type="service" id="Doctrine\DBAL\Connection"/>
            <tag name="messenger.message_handler"/>
        </service>

        <!-- Sales Channel API -->
        <service id="Shopwell\Core\Checkout\Payment\SalesChannel\PaymentMethodRoute" public="true">
            <argument type="service" id="sales_channel.payment_method.repository"/>
            <argument type="service" id="Shopwell\Core\Framework\Adapter\Cache\CacheTagCollector"/>
            <argument type="service" id="Shopwell\Core\Framework\Script\Execution\ScriptExecutor"/>
            <argument type="service" id="Shopwell\Core\Framework\Rule\RuleIdMatcher"/>
        </service>

        <service id="Shopwell\Core\Checkout\Payment\SalesChannel\HandlePaymentMethodRoute" public="true">
            <argument type="service" id="Shopwell\Core\Checkout\Payment\PaymentProcessor"/>
            <argument type="service" id="Shopwell\Core\Framework\Validation\DataValidator"/>
            <argument type="service" id="Shopwell\Core\System\SalesChannel\Context\SalesChannelContextService"/>
            <argument type="service" id="currency.repository"/>
        </service>
    </services>
</container>
