<?xml version="1.0" ?>

<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>
        <!-- Theme -->
        <service id="Shopwell\Storefront\Theme\StorefrontPluginConfiguration\StorefrontPluginConfigurationFactory">
            <argument type="service" id="Shopwell\Core\Framework\Plugin\KernelPluginLoader\KernelPluginLoader"/>
            <argument type="service" id="Shopwell\Core\Framework\App\Source\SourceResolver"/>
            <argument type="service" id="Symfony\Component\Filesystem\Filesystem"/>
        </service>

        <service id="Shopwell\Storefront\Theme\StorefrontPluginRegistry" public="true">
            <argument type="service" id="kernel"/>
            <argument type="service" id="Shopwell\Storefront\Theme\StorefrontPluginConfiguration\StorefrontPluginConfigurationFactory"/>
            <argument type="service" id="Shopwell\Core\Framework\App\ActiveAppsLoader"/>

            <tag name="kernel.reset" method="reset"/>
        </service>

        <service id="Shopwell\Storefront\Theme\ScssPhpCompiler" />

        <service id="Shopwell\Storefront\Theme\ThemeCompiler">
            <argument type="service" id="shopwell.filesystem.theme"/>
            <argument type="service" id="shopwell.filesystem.temp"/>
            <argument type="service" id="Shopwell\Core\Framework\Adapter\Filesystem\Plugin\CopyBatchInputFactory" />
            <argument type="service" id="Shopwell\Storefront\Theme\ThemeFileResolver" />
            <argument>%kernel.debug%</argument>
            <argument type="service" id="Symfony\Component\EventDispatcher\EventDispatcherInterface" />
            <argument type="service" id="Shopwell\Storefront\Theme\ThemeFilesystemResolver" />
            <argument type="tagged_iterator" tag="shopwell.asset"/>
            <argument type="service" id="Shopwell\Core\Framework\Adapter\Cache\CacheInvalidator"/>
            <argument type="service" id="Psr\Log\LoggerInterface"/>
            <argument type="service" id="Shopwell\Storefront\Theme\AbstractThemePathBuilder"/>
            <argument type="service" id="Shopwell\Storefront\Theme\ScssPhpCompiler"/>
            <argument>%storefront.theme.allowed_scss_values%</argument>
            <argument>%storefront.theme.validate_on_compile%</argument>
            <argument>%shopwell.filesystem.theme.visibility%</argument>
        </service>

        <service id="Shopwell\Storefront\Theme\ThemeLifecycleService">
            <argument type="service" id="Shopwell\Storefront\Theme\StorefrontPluginRegistry"/>
            <argument type="service" id="theme.repository"/>
            <argument type="service" id="media.repository"/>
            <argument type="service" id="media_folder.repository"/>
            <argument type="service" id="theme_media.repository"/>
            <argument type="service" id="Shopwell\Core\Content\Media\File\FileSaver"/>
            <argument type="service" id="Shopwell\Core\Content\Media\File\FileNameProvider"/>
            <argument type="service" id="Shopwell\Storefront\Theme\ThemeFilesystemResolver"/>
            <argument type="service" id="language.repository"/>
            <argument type="service" id="theme_child.repository"/>
            <argument type="service" id="Doctrine\DBAL\Connection"/>
            <argument type="service" id="Shopwell\Storefront\Theme\StorefrontPluginConfiguration\StorefrontPluginConfigurationFactory" on-invalid="null"/>
            <argument type="service" id="Shopwell\Storefront\Theme\ThemeRuntimeConfigService"/>
        </service>

        <service id="Shopwell\Storefront\Theme\ThemeFileResolver">
            <argument type="service" id="Shopwell\Storefront\Theme\ThemeFilesystemResolver"/>
        </service>

        <service id="Shopwell\Storefront\Theme\ThemeScripts">
            <argument type="service" id="request_stack"/>
            <argument type="service" id="Shopwell\Storefront\Theme\ThemeRuntimeConfigService"/>
        </service>

        <service id="Shopwell\Storefront\Theme\ThemeMergedConfigBuilder">
            <argument type="service" id="Shopwell\Storefront\Theme\StorefrontPluginRegistry"/>
            <argument type="service" id="theme.repository"/>
        </service>

        <service id="Shopwell\Storefront\Theme\ThemeService">
            <argument type="service" id="Shopwell\Storefront\Theme\StorefrontPluginRegistry"/>
            <argument type="service" id="theme.repository"/>
            <argument type="service" id="theme_sales_channel.repository"/>
            <argument type="service" id="Shopwell\Storefront\Theme\ThemeCompiler"/>
            <argument type="service" id="Shopwell\Storefront\Theme\ScssPhpCompiler"/>
            <argument type="service" id="event_dispatcher"/>
            <argument type="service" id="Shopwell\Storefront\Theme\ConfigLoader\AbstractConfigLoader"/>
            <argument type="service" id="Doctrine\DBAL\Connection"/>
            <argument type="service" id="Shopwell\Core\System\SystemConfig\SystemConfigService"/>
            <argument type="service" id="messenger.default_bus"/>
            <argument type="service" id="Shopwell\Core\Framework\Notification\NotificationService"/>
            <argument type="service" id="Shopwell\Storefront\Theme\ThemeMergedConfigBuilder"/>
            <argument type="service" id="Shopwell\Storefront\Theme\ThemeRuntimeConfigService"/>
        </service>

        <service id="Shopwell\Storefront\Theme\ResolvedConfigLoader" lazy="true">
            <argument type="service" id="media.repository"/>
            <argument type="service" id="Shopwell\Storefront\Theme\ThemeRuntimeConfigService"/>
        </service>

        <service id="Shopwell\Storefront\Theme\ThemeConfigCacheInvalidator">
            <argument type="service" id="Shopwell\Core\Framework\Adapter\Cache\CacheInvalidator"/>

            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Shopwell\Storefront\Theme\ThemeLifecycleHandler">
            <argument type="service" id="Shopwell\Storefront\Theme\ThemeLifecycleService"/>
            <argument type="service" id="Shopwell\Storefront\Theme\ThemeService"/>
            <argument type="service" id="theme.repository"/>
            <argument type="service" id="Shopwell\Storefront\Theme\StorefrontPluginRegistry"/>
            <argument type="service" id="Doctrine\DBAL\Connection"/>
        </service>


        <service id="Shopwell\Storefront\Theme\ThemeAppLifecycleHandler">
            <argument type="service" id="Shopwell\Storefront\Theme\StorefrontPluginRegistry"/>
            <argument type="service" id="Shopwell\Storefront\Theme\StorefrontPluginConfiguration\StorefrontPluginConfigurationFactory"/>
            <argument type="service" id="Shopwell\Storefront\Theme\ThemeLifecycleHandler"/>

            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Shopwell\Storefront\Theme\ConfigLoader\DatabaseAvailableThemeProvider">
            <argument type="service" id="Doctrine\DBAL\Connection"/>
        </service>

        <service id="Shopwell\Storefront\Theme\ConfigLoader\DatabaseConfigLoader">
            <argument type="service" id="theme.repository"/>
            <argument type="service" id="Shopwell\Storefront\Theme\StorefrontPluginRegistry"/>
            <argument type="service" id="media.repository"/>
        </service>

        <service id="Shopwell\Storefront\Theme\ThemeRuntimeConfigStorage">
            <argument type="service" id="Doctrine\DBAL\Connection"/>
        </service>

        <service id="Shopwell\Storefront\Theme\ThemeRuntimeConfigService">
            <argument type="service" id="Shopwell\Storefront\Theme\ThemeFileResolver"/>
            <argument type="service" id="Shopwell\Storefront\Theme\StorefrontPluginRegistry"/>
            <argument type="service" id="Shopwell\Storefront\Theme\ThemeMergedConfigBuilder"/>
            <argument type="service" id="Shopwell\Storefront\Theme\ThemeRuntimeConfigStorage"/>
        </service>

        <service id="Shopwell\Storefront\Theme\SeedingThemePathBuilder" lazy="true">
            <argument type="service" id="Shopwell\Core\System\SystemConfig\SystemConfigService"/>
        </service>

        <service id="Shopwell\Storefront\Theme\MD5ThemePathBuilder"/>

        <service id="Shopwell\Storefront\Theme\Message\CompileThemeHandler">
            <argument type="service" id="Shopwell\Storefront\Theme\ThemeCompiler"/>
            <argument type="service" id="Shopwell\Storefront\Theme\ConfigLoader\AbstractConfigLoader"/>
            <argument type="service" id="Shopwell\Storefront\Theme\StorefrontPluginRegistry"/>
            <argument type="service" id="Shopwell\Core\Framework\Notification\NotificationService"/>
            <argument type="service" id="sales_channel.repository" />
            <argument type="service" id="Shopwell\Storefront\Theme\ThemeRuntimeConfigService"/>

            <tag name="messenger.message_handler" />
        </service>

        <service id="Shopwell\Storefront\Theme\ScheduledTask\DeleteThemeFilesTask">
            <tag name="shopwell.scheduled.task"/>
        </service>

        <service id="Shopwell\Storefront\Theme\ScheduledTask\DeleteThemeFilesTaskHandler">
            <argument type="service" id="scheduled_task.repository"/>
            <argument type="service" id="logger"/>
            <argument type="service" id="Doctrine\DBAL\Connection"/>
            <argument type="service" id="shopwell.filesystem.theme"/>
            <argument type="service" id="Shopwell\Storefront\Theme\AbstractThemePathBuilder"/>

            <tag name="messenger.message_handler"/>
        </service>

        <service id="Shopwell\Storefront\Theme\ConfigLoader\StaticFileConfigLoader">
            <argument type="service" id="shopwell.filesystem.private"/>
        </service>

        <service id="Shopwell\Storefront\Theme\ConfigLoader\StaticFileAvailableThemeProvider">
            <argument type="service" id="shopwell.filesystem.private"/>
        </service>

        <service id="Shopwell\Storefront\Theme\ConfigLoader\StaticFileConfigDumper">
            <argument type="service" id="Shopwell\Storefront\Theme\ConfigLoader\DatabaseConfigLoader"/>
            <argument type="service" id="Shopwell\Storefront\Theme\ConfigLoader\DatabaseAvailableThemeProvider"/>
            <argument type="service" id="shopwell.filesystem.private"/>
            <argument type="service" id="shopwell.filesystem.temp"/>
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="shopwell.asset.theme" class="Shopwell\Storefront\Theme\ThemeAssetPackage" lazy="true">
            <argument type="collection">
                <argument>%shopwell.filesystem.theme.url%</argument>
            </argument>
            <argument type="service" id="shopwell.asset.theme.version_strategy"/>
            <argument type="service" id="request_stack"/>
            <argument type="service" id="Shopwell\Storefront\Theme\AbstractThemePathBuilder"/>
            <tag name="shopwell.asset" asset="theme"/>
        </service>

        <!-- Entity definitions -->
        <service id="Shopwell\Storefront\Theme\ThemeDefinition">
            <tag name="shopwell.entity.definition"/>
        </service>

        <service id="Shopwell\Storefront\Theme\Aggregate\ThemeTranslationDefinition">
            <tag name="shopwell.entity.definition"/>
        </service>

        <service id="Shopwell\Storefront\Theme\Aggregate\ThemeSalesChannelDefinition">
            <tag name="shopwell.entity.definition"/>
        </service>

        <service id="Shopwell\Storefront\Theme\Aggregate\ThemeMediaDefinition">
            <tag name="shopwell.entity.definition"/>
        </service>

        <service id="Shopwell\Storefront\Theme\Aggregate\ThemeChildDefinition">
            <tag name="shopwell.entity.definition"/>
        </service>

        <!-- Entity extensions -->
        <service id="Shopwell\Storefront\Theme\Extension\SalesChannelExtension">
            <tag name="shopwell.entity.extension"/>
        </service>

        <service id="Shopwell\Storefront\Theme\Extension\LanguageExtension">
            <tag name="shopwell.entity.extension"/>
        </service>

        <service id="Shopwell\Storefront\Theme\Extension\MediaExtension">
            <tag name="shopwell.entity.extension"/>
        </service>

        <!-- Controller -->
        <service id="Shopwell\Storefront\Theme\Controller\ThemeController" public="true">
            <argument type="service" id="Shopwell\Storefront\Theme\ThemeService"/>
            <argument type="service" id="Shopwell\Storefront\Theme\ScssPhpCompiler"/>
            <argument>%storefront.theme.allowed_scss_values%</argument>
            <call method="setContainer">
                <argument type="service" id="service_container"/>
            </call>
        </service>

        <!--  Commands -->
        <service id="Shopwell\Storefront\Theme\Command\ThemeCreateCommand">
            <argument>%kernel.project_dir%</argument>
            <argument type="service" id="Symfony\Component\Filesystem\Filesystem"/>

            <tag name="console.command"/>
        </service>

        <service id="Shopwell\Storefront\Theme\Command\ThemeChangeCommand">
            <argument type="service" id="Shopwell\Storefront\Theme\ThemeService"/>
            <argument type="service" id="Shopwell\Storefront\Theme\StorefrontPluginRegistry"/>
            <argument type="service" id="sales_channel.repository"/>
            <argument type="service" id="theme.repository"/>
            <argument type="service" id="theme_sales_channel.repository"/>
            <argument type="service" id="media_thumbnail.repository"/>

            <tag name="console.command"/>
        </service>

        <service id="Shopwell\Storefront\Theme\Command\ThemeCompileCommand">
            <argument type="service" id="Shopwell\Storefront\Theme\ThemeService"/>
            <argument type="service" id="Shopwell\Storefront\Theme\ConfigLoader\AbstractAvailableThemeProvider"/>

            <tag name="console.command"/>
        </service>

        <service id="Shopwell\Storefront\Theme\Command\ThemeDumpCommand">
            <argument type="service" id="Shopwell\Storefront\Theme\StorefrontPluginRegistry"/>
            <argument type="service" id="Shopwell\Storefront\Theme\ThemeFileResolver"/>
            <argument type="service" id="theme.repository"/>
            <argument type="service" id="Shopwell\Storefront\Theme\ConfigLoader\StaticFileConfigDumper"/>
            <argument type="service" id="Shopwell\Storefront\Theme\ThemeFilesystemResolver"/>

            <tag name="console.command"/>
        </service>

        <service id="Shopwell\Storefront\Theme\Command\ThemeRefreshCommand">
            <argument type="service" id="Shopwell\Storefront\Theme\ThemeLifecycleService"/>

            <tag name="console.command"/>
        </service>

        <service id="Shopwell\Storefront\Theme\Command\ThemePrepareIconsCommand">

            <tag name="console.command"/>
        </service>

        <!-- Subscriber -->
        <service id="Shopwell\Storefront\Theme\Subscriber\PluginLifecycleSubscriber">
            <argument type="service" id="Shopwell\Storefront\Theme\StorefrontPluginRegistry"/>
            <argument>%kernel.project_dir%</argument>
            <argument type="service" id="Shopwell\Storefront\Theme\StorefrontPluginConfiguration\StorefrontPluginConfigurationFactory"/>
            <argument type="service" id="Shopwell\Storefront\Theme\ThemeLifecycleHandler"/>
            <argument type="service" id="Shopwell\Storefront\Theme\ThemeLifecycleService"/>

            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Shopwell\Storefront\Theme\Twig\ThemeInheritanceBuilderInterface"
                 class="Shopwell\Storefront\Theme\Twig\ThemeInheritanceBuilder">
            <argument type="service" id="Shopwell\Storefront\Theme\ThemeRuntimeConfigService"/>
        </service>

        <service id="Shopwell\Storefront\Theme\Subscriber\AppLifecycleSubscriber">
            <argument type="service" id="Shopwell\Storefront\Theme\ThemeLifecycleService"/>
            <argument type="service" id="app.repository"/>

            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Shopwell\Storefront\Theme\Subscriber\ThemeCompilerEnrichScssVarSubscriber">
            <argument type="service" id="Shopwell\Core\System\SystemConfig\Service\ConfigurationService"/>
            <argument type="service" id="Shopwell\Storefront\Theme\StorefrontPluginRegistry"/>

            <tag name="kernel.event_subscriber"/>
        </service>

        <!-- Twig -->
        <service id="Shopwell\Storefront\Theme\Twig\ThemeNamespaceHierarchyBuilder">
            <argument type="service" id="Shopwell\Storefront\Theme\Twig\ThemeInheritanceBuilderInterface"/>
            <argument type="service" id="Shopwell\Storefront\Theme\DatabaseSalesChannelThemeLoader"/>

            <tag name="kernel.event_subscriber" />
            <tag name="kernel.reset" method="reset"/>

            <!-- Make sure it runs after default `BundleHierarchyBuilder` -->
            <tag name="shopwell.twig.hierarchy_builder" priority="500"/>
        </service>

        <service id="Shopwell\Storefront\Theme\Subscriber\FirstRunWizardSubscriber">
            <argument type="service" id="Shopwell\Storefront\Theme\ThemeService"/>
            <argument type="service" id="Shopwell\Storefront\Theme\ThemeLifecycleService"/>
            <argument type="service" id="theme.repository" />
            <argument type="service" id="theme_sales_channel.repository" />
            <argument type="service" id="sales_channel.repository" />

            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Shopwell\Storefront\Theme\Subscriber\UpdateSubscriber">
            <argument type="service" id="Shopwell\Storefront\Theme\ThemeService"/>
            <argument type="service" id="Shopwell\Storefront\Theme\ThemeLifecycleService"/>
            <argument type="service" id="sales_channel.repository" />

            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Shopwell\Storefront\Theme\Subscriber\UnusedMediaSubscriber">
            <argument type="service" id="theme.repository"/>
            <argument type="service" id="Shopwell\Storefront\Theme\ThemeService"/>

            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Shopwell\Storefront\Theme\DataAbstractionLayer\ThemeIndexer">
            <tag name="shopwell.entity_indexer"/>
            <argument type="service" id="Shopwell\Core\Framework\DataAbstractionLayer\Dbal\Common\IteratorFactory"/>
            <argument type="service" id="theme.repository"/>
            <argument type="service" id="Doctrine\DBAL\Connection"/>
            <argument type="service" id="event_dispatcher"/>
        </service>

        <service id="Shopwell\Storefront\Theme\DatabaseSalesChannelThemeLoader" public="true">
            <argument type="service" id="Doctrine\DBAL\Connection"/>
        </service>

        <service id="Shopwell\Storefront\Theme\ThemeFilesystemResolver" public="true">
            <argument type="service" id="Shopwell\Core\Framework\App\Source\SourceResolver"/>
            <argument type="service" id="kernel"></argument>
        </service>

        <service id="Shopwell\Storefront\Theme\Subscriber\ThemeSnippetsSubscriber">
            <argument type="service" id="Shopwell\Storefront\Theme\ThemeRuntimeConfigService"/>
            <argument type="service" id="Shopwell\Storefront\Theme\DatabaseSalesChannelThemeLoader"/>

            <tag name="kernel.event_subscriber"/>
        </service>
    </services>
</container>
