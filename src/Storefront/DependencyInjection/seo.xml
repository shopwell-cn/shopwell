<?xml version="1.0" ?>

<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>
        <service id="Shopwell\Storefront\Framework\Seo\SeoUrlRoute\ProductPageSeoUrlRoute">
            <argument type="service" id="Shopwell\Core\Content\Product\ProductDefinition"/>

            <tag name="shopwell.seo_url.route"/>
        </service>

        <service id="Shopwell\Storefront\Framework\Seo\SeoUrlRoute\NavigationPageSeoUrlRoute">
            <argument type="service" id="Shopwell\Core\Content\Category\CategoryDefinition"/>
            <argument type="service" id="Shopwell\Core\Content\Category\Service\CategoryBreadcrumbBuilder"/>

            <tag name="shopwell.seo_url.route"/>
        </service>

        <service id="Shopwell\Storefront\Framework\Seo\SeoUrlRoute\LandingPageSeoUrlRoute">
            <argument type="service" id="Shopwell\Core\Content\LandingPage\LandingPageDefinition"/>

            <tag name="shopwell.seo_url.route"/>
        </service>

        <service id="Shopwell\Storefront\Framework\Seo\SeoUrlRoute\SeoUrlUpdateListener">
            <argument type="service" id="Shopwell\Core\Content\Seo\SeoUrlUpdater"/>
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Shopwell\Storefront\Framework\Seo\SeoUrlRouteNameEnumProvider">
            <argument type="service" id="Shopwell\Core\Content\Seo\SeoUrlRoute\SeoUrlRouteRegistry"/>
            <tag name="shopwell.api.enum_provider" />
        </service>
    </services>
</container>
