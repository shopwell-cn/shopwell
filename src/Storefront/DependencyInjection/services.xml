<?xml version="1.0" ?>

<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">

    <parameters>
        <parameter key="shopwell.twig.app_variable.allowed_server_params" type="collection">
            <parameter>server_name</parameter>
            <parameter>request_uri</parameter>
            <parameter>app_url</parameter>
            <parameter>http_user_agent</parameter>
            <parameter>http_host</parameter>
            <parameter>server_name</parameter>
            <parameter>server_port</parameter>
            <parameter>redirect_url</parameter>
            <parameter>https</parameter>
            <parameter>forwarded</parameter>
            <parameter>host</parameter>
            <parameter>remote_addr</parameter>
            <parameter>http_x_forwarded_for</parameter>
            <parameter>http_x_forwarded_host</parameter>
            <parameter>http_x_forwarded_proto</parameter>
            <parameter>http_x_forwarded_port</parameter>
            <parameter>http_x_forwarded_prefix</parameter>
        </parameter>
    </parameters>

    <services>
        <defaults autowire="true"/>

        <!-- Checkout -->
        <service id="Shopwell\Storefront\Checkout\Cart\SalesChannel\StorefrontCartFacade">
            <argument type="service" id="Shopwell\Core\Checkout\Cart\SalesChannel\CartService"/>
            <argument type="service" id="Shopwell\Storefront\Checkout\Shipping\BlockedShippingMethodSwitcher"/>
            <argument type="service" id="Shopwell\Storefront\Checkout\Payment\BlockedPaymentMethodSwitcher"/>
            <argument type="service" id="Shopwell\Core\System\SalesChannel\SalesChannel\ContextSwitchRoute"/>
            <argument type="service" id="Shopwell\Core\Checkout\Cart\CartCalculator"/>
            <argument type="service" id="Shopwell\Core\Checkout\Cart\CartPersister"/>
        </service>

        <service id="Shopwell\Storefront\Checkout\Customer\CustomerGroupSubscriber">
            <argument type="service" id="customer_group.repository"/>
            <argument type="service" id="seo_url.repository"/>
            <argument type="service" id="language.repository"/>
            <argument type="service" id="Shopwell\Core\Content\Seo\SeoUrlPersister"/>
            <argument type="service" id="slugify"/>
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Shopwell\Storefront\Checkout\Shipping\BlockedShippingMethodSwitcher">
            <argument type="service" id="Shopwell\Core\Checkout\Shipping\SalesChannel\ShippingMethodRoute"/>
        </service>

        <service id="Shopwell\Storefront\Checkout\Payment\BlockedPaymentMethodSwitcher">
            <argument type="service" id="Shopwell\Core\Checkout\Payment\SalesChannel\PaymentMethodRoute"/>
        </service>

        <service id="Shopwell\Storefront\Framework\Cache\CacheCookieEventSubscriber">
            <argument type="service" id="session.factory"/>

            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Shopwell\Storefront\Framework\Routing\CachedDomainLoader" decorates="Shopwell\Storefront\Framework\Routing\DomainLoader" decoration-priority="-1000">
            <argument type="service" id="Shopwell\Storefront\Framework\Routing\CachedDomainLoader.inner"/>
            <argument type="service" id="cache.object"/>
            <argument type="service" id="logger"/>
        </service>

        <service id="Shopwell\Storefront\Framework\Routing\CachedDomainLoaderInvalidator">
            <argument type="service" id="Shopwell\Core\Framework\Adapter\Cache\CacheInvalidator"/>
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Shopwell\Storefront\Framework\Routing\DomainLoader">
            <argument type="service" id="Doctrine\DBAL\Connection"/>
        </service>

        <service id="Shopwell\Storefront\Framework\Routing\RequestTransformer"
                 decorates="Shopwell\Core\Framework\Routing\RequestTransformerInterface" public="true">

            <argument type="service" id="Shopwell\Storefront\Framework\Routing\RequestTransformer.inner"/>
            <argument type="service" id="Shopwell\Core\Content\Seo\SeoResolver"/>
            <argument>%shopwell.routing.registered_api_prefixes%</argument>
            <argument type="service" id="Shopwell\Storefront\Framework\Routing\DomainLoader"/>
        </service>

        <service id="Shopwell\Storefront\Framework\Routing\Router" decorates="router">
            <argument type="service" id="Shopwell\Storefront\Framework\Routing\Router.inner"/>
            <argument type="service" id="request_stack"/>
            <argument>%storefront.router.allowed_routes%</argument>
        </service>

        <service id="Shopwell\Storefront\Framework\Routing\MaintenanceModeResolver">
            <argument type="service" id="request_stack"/>
            <argument type="service" id="Shopwell\Core\Framework\Routing\MaintenanceModeResolver"/>
        </service>

        <service id="Shopwell\Storefront\Framework\Routing\StorefrontRouteScope">
            <tag name="shopwell.route_scope"/>
        </service>

        <service id="Shopwell\Storefront\Framework\Twig\TemplateDataExtension">
            <argument type="service" id="request_stack"/>
            <argument>%shopwell.staging.storefront.show_banner%</argument>
            <argument type="service" id="Doctrine\DBAL\Connection"/>

            <tag name="twig.extension"/>
        </service>

        <service id="Shopwell\Storefront\Framework\Twig\TemplateConfigAccessor">
            <argument type="service" id="Shopwell\Core\System\SystemConfig\SystemConfigService"/>
            <argument type="service" id="Shopwell\Storefront\Theme\ThemeConfigValueAccessor"/>
            <argument type="service" id="Shopwell\Storefront\Theme\ThemeScripts" />
        </service>

        <service id="Shopwell\Storefront\Theme\ThemeConfigValueAccessor">
            <argument type="service" id="Shopwell\Storefront\Theme\ResolvedConfigLoader"/>
            <argument type="service" id="Shopwell\Core\Framework\Adapter\Cache\CacheTagCollector"/>
        </service>

        <service id="Shopwell\Storefront\Framework\Twig\Extension\ConfigExtension">
            <argument type="service" id="Shopwell\Storefront\Framework\Twig\TemplateConfigAccessor"/>
            <tag name="twig.extension"/>
        </service>

        <service id="Shopwell\Storefront\Framework\Twig\IconExtension">
            <tag name="twig.extension"/>
        </service>

        <service id="Shopwell\Storefront\Framework\Twig\ThumbnailExtension">
            <argument type="service" id="Shopwell\Core\Framework\Adapter\Twig\TemplateFinder"/>

            <tag name="twig.extension"/>
        </service>

        <service id="Shopwell\Storefront\Framework\Twig\TwigDateRequestListener">
            <argument type="service" id="service_container"/>
            <tag name="kernel.event_listener" event="kernel.request"/>
        </service>

        <service id="Shopwell\Storefront\Framework\Twig\ErrorTemplateResolver" public="false">
            <argument type="service" id="twig"/>
        </service>

        <service id="Shopwell\Storefront\Framework\Twig\Extension\UrlEncodingTwigFilter" public="false">
            <tag name="twig.extension"/>
        </service>

        <service id="Shopwell\Storefront\Framework\Twig\Extension\IconCacheTwigFilter" public="false">
            <tag name="twig.extension"/>
        </service>

        <service id="Shopwell\Storefront\Framework\Media\StorefrontMediaUploader">
            <argument type="service" id="Shopwell\Core\Content\Media\MediaService"/>
            <argument type="service" id="Shopwell\Core\Content\Media\File\FileSaver"/>
            <argument type="service" id="Shopwell\Storefront\Framework\Media\StorefrontMediaValidatorRegistry"/>
        </service>

        <service id="Shopwell\Storefront\Framework\Media\StorefrontMediaValidatorRegistry" public="true">
            <argument type="tagged_iterator" tag="storefront.media.upload.validator"/>
        </service>

        <service id="Shopwell\Storefront\Framework\Media\Validator\StorefrontMediaImageValidator">
            <tag name="storefront.media.upload.validator"/>
        </service>

        <service id="Shopwell\Storefront\Framework\Media\Validator\StorefrontMediaDocumentValidator">
            <tag name="storefront.media.upload.validator"/>
        </service>

        <service id="Shopwell\Storefront\Framework\Routing\StorefrontSubscriber">
            <argument type="service" id="request_stack"/>
            <argument type="service" id="router"/>
            <argument type="service" id="Shopwell\Storefront\Framework\Routing\MaintenanceModeResolver"/>
            <argument type="service" id="Shopwell\Core\System\SystemConfig\SystemConfigService"/>
            <argument type="service" id="event_dispatcher"/>

            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Shopwell\Storefront\Framework\Routing\TemplateDataSubscriber">
            <argument type="service" id="Shopwell\Core\Content\Seo\HreflangLoaderInterface"/>
            <argument type="service" id="Shopwell\Core\Framework\App\ShopId\ShopIdProvider"/>
            <argument type="service" id="Shopwell\Core\Framework\App\ActiveAppsLoader"/>
            <argument type="service" id="Shopwell\Storefront\Theme\ThemeRuntimeConfigService"/>
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Shopwell\Storefront\Framework\Routing\CanonicalLinkListener">
            <tag name="kernel.event_listener" event="Shopwell\Core\Framework\Event\BeforeSendResponseEvent"/>
        </service>

        <service id="Shopwell\Storefront\Framework\Routing\NotFound\NotFoundSubscriber">
            <argument type="service" id="http_kernel"/>
            <argument type="service" id="Shopwell\Core\System\SalesChannel\Context\SalesChannelContextService"/>
            <argument>%kernel.debug%</argument>
            <argument type="service" id="cache.object"/>
            <argument type="service" id="Shopwell\Core\Framework\DataAbstractionLayer\Cache\EntityCacheKeyGenerator"/>
            <argument type="service" id="Shopwell\Core\Framework\Adapter\Cache\CacheInvalidator"/>
            <argument type="service" id="event_dispatcher"/>
            <argument>%session.storage.options%</argument>

            <tag name="kernel.event_subscriber"/>
            <tag name="kernel.reset" method="reset"/>
        </service>

        <service id="Shopwell\Storefront\Framework\AffiliateTracking\AffiliateTrackingListener">
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Shopwell\Storefront\Page\Navigation\NavigationPageLoader">
            <argument type="service" id="Shopwell\Storefront\Page\GenericPageLoader"/>
            <argument type="service" id="event_dispatcher"/>
            <argument type="service" id="Shopwell\Core\Content\Category\SalesChannel\CategoryRoute"/>
            <argument type="service" id="Shopwell\Core\Content\Seo\SeoUrlPlaceholderHandlerInterface"/>
        </service>

        <service id="Shopwell\Storefront\Page\Navigation\Error\ErrorPageLoader">
            <argument type="service" id="Shopwell\Storefront\Page\GenericPageLoader"/>
            <argument type="service" id="event_dispatcher"/>
        </service>

        <service id="Shopwell\Storefront\Page\LandingPage\LandingPageLoader">
            <argument type="service" id="Shopwell\Storefront\Page\GenericPageLoader"/>
            <argument type="service" id="Shopwell\Core\Content\LandingPage\SalesChannel\LandingPageRoute"/>
            <argument type="service" id="event_dispatcher"/>
        </service>

        <service id="Shopwell\Storefront\Pagelet\Menu\Offcanvas\MenuOffcanvasPageletLoader">
            <argument type="service" id="event_dispatcher"/>
            <argument type="service" id="Shopwell\Core\Content\Category\Service\NavigationLoader"/>
        </service>

        <service id="Shopwell\Storefront\Pagelet\Captcha\BasicCaptchaPageletLoader">
            <argument type="service" id="event_dispatcher"/>
            <argument type="service" id="Shopwell\Storefront\Framework\Captcha\BasicCaptcha\BasicCaptchaGenerator"/>
            <argument type="service" id="Shopwell\Core\Content\Category\Service\NavigationLoader"/>
        </service>

        <service id="Shopwell\Storefront\Pagelet\Country\CountryStateDataPageletLoader">
            <argument type="service" id="Shopwell\Core\System\Country\SalesChannel\CountryStateRoute"/>
            <argument type="service" id="event_dispatcher"/>
        </service>

        <service id="Shopwell\Storefront\Page\Suggest\SuggestPageLoader">
            <argument type="service" id="event_dispatcher"/>
            <argument type="service" id="Shopwell\Core\Content\Product\SalesChannel\Suggest\ProductSuggestRoute"/>
            <argument type="service" id="Shopwell\Storefront\Page\GenericPageLoader"/>
        </service>

        <service id="Shopwell\Storefront\Pagelet\Header\HeaderPageletLoader">
            <argument type="service" id="event_dispatcher"/>
            <argument type="service" id="Shopwell\Core\System\Currency\SalesChannel\CurrencyRoute"/>
            <argument type="service" id="Shopwell\Core\System\Language\SalesChannel\LanguageRoute"/>
            <argument type="service" id="Shopwell\Core\Content\Category\Service\NavigationLoader"/>
        </service>

        <service id="Shopwell\Storefront\Pagelet\Footer\FooterPageletLoader">
            <argument type="service" id="event_dispatcher"/>
            <argument type="service" id="Shopwell\Core\Content\Category\Service\NavigationLoader"/>
            <argument type="service" id="Shopwell\Core\Checkout\Payment\SalesChannel\PaymentMethodRoute"/>
            <argument type="service" id="Shopwell\Core\Checkout\Shipping\SalesChannel\ShippingMethodRoute"/>
        </service>

        <service id="Shopwell\Storefront\Page\GenericPageLoader">
            <argument type="service" id="Shopwell\Core\System\SystemConfig\SystemConfigService"/>
            <argument type="service" id="event_dispatcher"/>
        </service>

        <service id="Shopwell\Storefront\Page\Search\SearchPageLoader" public="true">
            <argument type="service" id="Shopwell\Storefront\Page\GenericPageLoader"/>
            <argument type="service" id="Shopwell\Core\Content\Product\SalesChannel\Search\ProductSearchRoute"/>
            <argument type="service" id="event_dispatcher"/>
            <argument type="service" id="Shopwell\Core\Framework\Adapter\Translation\Translator"/>
        </service>

        <service id="Shopwell\Storefront\Page\Product\ProductPageLoader">
            <argument type="service" id="Shopwell\Storefront\Page\GenericPageLoader"/>
            <argument type="service" id="event_dispatcher"/>
            <argument type="service" id="Shopwell\Core\Content\Product\SalesChannel\Detail\ProductDetailRoute"/>
        </service>

        <service id="Shopwell\Storefront\Page\Product\QuickView\MinimalQuickViewPageLoader">
            <argument type="service" id="event_dispatcher"/>
            <argument type="service" id="Shopwell\Core\Content\Product\SalesChannel\Detail\ProductDetailRoute"/>
        </service>

        <service id="Shopwell\Storefront\Page\Product\Configurator\ProductPageConfiguratorLoader"
                 decorates="Shopwell\Core\Content\Product\SalesChannel\Detail\ProductConfiguratorLoader">

            <argument type="service" id="Shopwell\Storefront\Page\Product\Configurator\ProductPageConfiguratorLoader.inner"/>
        </service>

        <service id="Shopwell\Storefront\Page\Checkout\Finish\CheckoutFinishPageLoader">
            <argument type="service" id="event_dispatcher"/>
            <argument type="service" id="Shopwell\Storefront\Page\GenericPageLoader"/>
            <argument type="service" id="Shopwell\Core\Checkout\Order\SalesChannel\OrderRoute"/>
            <argument type="service" id="Shopwell\Core\Framework\Adapter\Translation\Translator"/>
            <argument type="service" id="Shopwell\Core\System\SystemConfig\SystemConfigService"/>
        </service>

        <service id="Shopwell\Storefront\Page\Checkout\Confirm\CheckoutConfirmPageLoader">
            <argument type="service" id="event_dispatcher"/>
            <argument type="service" id="Shopwell\Storefront\Checkout\Cart\SalesChannel\StorefrontCartFacade"/>
            <argument type="service" id="Shopwell\Core\Checkout\Gateway\SalesChannel\CheckoutGatewayRoute"/>
            <argument type="service" id="Shopwell\Storefront\Page\GenericPageLoader"/>
            <argument type="service" id="Shopwell\Core\Checkout\Customer\Validation\AddressValidationFactory"/>
            <argument type="service" id="Shopwell\Core\Framework\Validation\DataValidator"/>
            <argument type="service" id="Shopwell\Core\Framework\Adapter\Translation\Translator"/>
        </service>

        <service id="Shopwell\Storefront\Page\Checkout\Cart\CheckoutCartPageLoader">
            <argument type="service" id="Shopwell\Storefront\Page\GenericPageLoader"/>
            <argument type="service" id="event_dispatcher"/>
            <argument type="service" id="Shopwell\Storefront\Checkout\Cart\SalesChannel\StorefrontCartFacade"/>
            <argument type="service" id="Shopwell\Core\Checkout\Gateway\SalesChannel\CheckoutGatewayRoute"/>
            <argument type="service" id="Shopwell\Core\System\Country\SalesChannel\CountryRoute"/>
            <argument type="service" id="Shopwell\Core\Framework\Adapter\Translation\Translator"/>
        </service>

        <service id="Shopwell\Storefront\Page\Checkout\Offcanvas\OffcanvasCartPageLoader">
            <argument type="service" id="event_dispatcher"/>
            <argument type="service" id="Shopwell\Storefront\Checkout\Cart\SalesChannel\StorefrontCartFacade"/>
            <argument type="service" id="Shopwell\Storefront\Page\GenericPageLoader"/>
            <argument type="service" id="Shopwell\Core\Checkout\Shipping\SalesChannel\ShippingMethodRoute"/>
        </service>

        <service id="Shopwell\Storefront\Page\Account\Profile\AccountProfilePageLoader">
            <argument type="service" id="Shopwell\Storefront\Page\GenericPageLoader"/>
            <argument type="service" id="event_dispatcher"/>
            <argument type="service" id="Shopwell\Core\Framework\Adapter\Translation\Translator"/>
        </service>

        <service id="Shopwell\Storefront\Page\Account\Overview\AccountOverviewPageLoader">
            <argument type="service" id="Shopwell\Storefront\Page\GenericPageLoader"/>
            <argument type="service" id="event_dispatcher"/>
            <argument type="service" id="Shopwell\Core\Checkout\Order\SalesChannel\OrderRoute"/>
            <argument type="service" id="Shopwell\Core\Checkout\Customer\SalesChannel\CustomerRoute"/>
            <argument type="service" id="Shopwell\Core\Framework\Adapter\Translation\Translator"/>
        </service>

        <service id="Shopwell\Storefront\Page\Account\Order\AccountOrderPageLoader">
            <argument type="service" id="Shopwell\Storefront\Page\GenericPageLoader"/>
            <argument type="service" id="event_dispatcher"/>
            <argument type="service" id="Shopwell\Core\Checkout\Order\SalesChannel\OrderRoute"/>
            <argument type="service" id="Shopwell\Core\Framework\Adapter\Translation\Translator"/>
        </service>

        <service id="Shopwell\Storefront\Page\Account\Order\AccountEditOrderPageLoader">
            <argument type="service" id="Shopwell\Storefront\Page\GenericPageLoader"/>
            <argument type="service" id="event_dispatcher"/>
            <argument type="service" id="Shopwell\Core\Checkout\Order\SalesChannel\OrderRoute"/>
            <argument type="service" id="Shopwell\Core\Checkout\Gateway\SalesChannel\CheckoutGatewayRoute"/>
            <argument type="service" id="Shopwell\Core\Checkout\Cart\Order\OrderConverter"/>
            <argument type="service" id="Shopwell\Core\Checkout\Order\SalesChannel\OrderService"/>
            <argument type="service" id="Shopwell\Core\Framework\Adapter\Translation\Translator"/>
            <argument type="service" id="Shopwell\Core\Checkout\Cart\SalesChannel\CartService"/>
        </service>

        <service id="Shopwell\Storefront\Page\Account\Login\AccountLoginPageLoader">
            <argument type="service" id="Shopwell\Storefront\Page\GenericPageLoader"/>
            <argument type="service" id="event_dispatcher"/>
            <argument type="service" id="Shopwell\Core\System\Country\SalesChannel\CountryRoute"/>
            <argument type="service" id="Shopwell\Core\Framework\Adapter\Translation\Translator"/>
        </service>

        <service id="Shopwell\Storefront\Page\Account\RecoverPassword\AccountRecoverPasswordPageLoader">
            <argument type="service" id="Shopwell\Storefront\Page\GenericPageLoader"/>
            <argument type="service" id="event_dispatcher"/>
            <argument type="service" id="Shopwell\Core\Checkout\Customer\SalesChannel\CustomerRecoveryIsExpiredRoute"/>
        </service>

        <service id="Shopwell\Storefront\Page\Account\CustomerGroupRegistration\CustomerGroupRegistrationPageLoader">
            <argument type="service" id="Shopwell\Storefront\Page\Account\Login\AccountLoginPageLoader"/>
            <argument type="service" id="Shopwell\Core\Checkout\Customer\SalesChannel\CustomerGroupRegistrationSettingsRoute"/>
            <argument type="service" id="event_dispatcher"/>
        </service>

        <service id="Shopwell\Storefront\Page\Checkout\Register\CheckoutRegisterPageLoader" public="true">
            <argument type="service" id="Shopwell\Storefront\Page\GenericPageLoader"/>
            <argument type="service" id="Shopwell\Core\Checkout\Customer\SalesChannel\ListAddressRoute"/>
            <argument type="service" id="event_dispatcher"/>
            <argument type="service" id="Shopwell\Core\Checkout\Cart\SalesChannel\CartService"/>
            <argument type="service" id="Shopwell\Core\System\Country\SalesChannel\CountryRoute"/>
            <argument type="service" id="Shopwell\Core\Framework\Adapter\Translation\Translator"/>
        </service>

        <service id="Shopwell\Storefront\Page\Address\Detail\AddressDetailPageLoader">
            <argument type="service" id="Shopwell\Storefront\Page\GenericPageLoader"/>
            <argument type="service" id="Shopwell\Core\System\Country\SalesChannel\CountryRoute"/>
            <argument type="service" id="event_dispatcher"/>
            <argument type="service" id="Shopwell\Core\Checkout\Customer\SalesChannel\ListAddressRoute"/>
            <argument type="service" id="Shopwell\Core\Framework\Adapter\Translation\Translator"/>
        </service>

        <service id="Shopwell\Storefront\Page\Address\Listing\AddressListingPageLoader">
            <argument type="service" id="Shopwell\Storefront\Page\GenericPageLoader"/>
            <argument type="service" id="Shopwell\Core\System\Country\SalesChannel\CountryRoute"/>
            <argument type="service" id="Shopwell\Core\Checkout\Customer\SalesChannel\ListAddressRoute"/>
            <argument type="service" id="event_dispatcher"/>
            <argument type="service" id="Shopwell\Core\Checkout\Cart\SalesChannel\CartService"/>
            <argument type="service" id="Shopwell\Core\Framework\Adapter\Translation\Translator"/>
        </service>

        <service id="Shopwell\Storefront\Page\Sitemap\SitemapPageLoader">
            <argument type="service" id="event_dispatcher"/>
            <argument type="service" id="Shopwell\Core\Content\Sitemap\SalesChannel\SitemapRoute"/>
        </service>

        <service id="Shopwell\Storefront\Framework\Command\SalesChannelCreateStorefrontCommand">
            <argument type="service" id="snippet_set.repository"/>
            <argument type="service" id="Shopwell\Core\Maintenance\SalesChannel\Service\SalesChannelCreator"/>

            <tag name="console.command"/>
        </service>

        <service id="Shopwell\Storefront\Framework\Routing\ResponseHeaderListener">
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Shopwell\Storefront\Event\CartMergedSubscriber">
            <argument type="service" id="translator"/>
            <argument type="service" id="request_stack"/>

            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Shopwell\Storefront\Page\Wishlist\WishlistPageLoader">
            <argument type="service" id="Shopwell\Storefront\Page\GenericPageLoader"/>
            <argument type="service" id="Shopwell\Core\Checkout\Customer\SalesChannel\LoadWishlistRoute"/>
            <argument type="service" id="event_dispatcher"/>
        </service>

        <service id="Shopwell\Storefront\Page\Wishlist\GuestWishlistPageLoader">
            <argument type="service" id="Shopwell\Storefront\Page\GenericPageLoader"/>
            <argument type="service" id="event_dispatcher"/>
        </service>

        <service id="Shopwell\Storefront\Pagelet\Wishlist\GuestWishlistPageletLoader">
            <argument type="service" id="Shopwell\Core\Content\Product\SalesChannel\ProductListRoute"/>
            <argument type="service" id="Shopwell\Core\System\SystemConfig\SystemConfigService"/>
            <argument type="service" id="event_dispatcher"/>
            <argument type="service" id="Shopwell\Core\Content\Product\SalesChannel\ProductCloseoutFilterFactory"/>
        </service>

        <service id="Shopwell\Storefront\Framework\App\Template\IconTemplateLoader" decorates="Shopwell\Core\Framework\App\Template\TemplateLoader">
            <argument type="service" id="Shopwell\Storefront\Framework\App\Template\IconTemplateLoader.inner"/>
            <argument type="service" id="Shopwell\Storefront\Theme\StorefrontPluginConfiguration\StorefrontPluginConfigurationFactory"/>
            <argument type="service" id="Shopwell\Core\Framework\App\Source\SourceResolver"/>
            <argument>%kernel.project_dir%</argument>
        </service>

        <service id="Shopwell\Storefront\Framework\Twig\TwigAppVariable" decorates="twig.app_variable">
            <argument type="service" id="Shopwell\Storefront\Framework\Twig\TwigAppVariable.inner"/>
            <argument>%shopwell.twig.app_variable.allowed_server_params%</argument>
        </service>

        <service id="Shopwell\Storefront\Framework\Routing\DomainNotMappedListener">
            <argument type="service" id="service_container"/>

            <tag name="kernel.event_listener" event="kernel.exception"/>
        </service>

        <service id="Shopwell\Storefront\Framework\SystemCheck\Util\SalesChannelDomainUtil">
            <argument type="service" id="Symfony\Component\Routing\RouterInterface"/>
            <argument type="service" id="Symfony\Component\HttpFoundation\RequestStack"/>
            <argument type="service" id="Symfony\Component\HttpKernel\KernelInterface"/>
            <argument type="service" id="logger"/>
        </service>

        <service id="Shopwell\Storefront\Framework\SystemCheck\SalesChannelsReadinessCheck">
            <argument type="service" id="Shopwell\Storefront\Framework\SystemCheck\Util\SalesChannelDomainUtil"/>
            <argument type="service" id="Shopwell\Storefront\Framework\SystemCheck\Util\SalesChannelDomainProvider"/>

            <tag name="shopwell.system_check"/>
        </service>

        <service id="Shopwell\Storefront\Framework\SystemCheck\ProductDetailReadinessCheck">
            <argument type="service" id="Shopwell\Storefront\Framework\SystemCheck\Util\SalesChannelDomainUtil"/>
            <argument type="service" id="Doctrine\DBAL\Connection"/>
            <argument type="service" id="Shopwell\Storefront\Framework\SystemCheck\Util\SalesChannelDomainProvider"/>

            <tag name="shopwell.system_check"/>
        </service>

        <service id="Shopwell\Storefront\Framework\SystemCheck\ProductListingReadinessCheck">
            <argument type="service" id="Shopwell\Storefront\Framework\SystemCheck\Util\SalesChannelDomainUtil"/>
            <argument type="service" id="Doctrine\DBAL\Connection"/>
            <argument type="service" id="Shopwell\Storefront\Framework\SystemCheck\Util\SalesChannelDomainProvider"/>

            <tag name="shopwell.system_check"/>
        </service>

        <service id="Shopwell\Storefront\Framework\SystemCheck\Util\SalesChannelDomainProvider">
            <argument type="service" id="Doctrine\DBAL\Connection"/>
        </service>

        <service id="Shopwell\Storefront\Page\Robots\Parser\RobotsDirectiveParser"/>

        <service id="Shopwell\Storefront\Page\Robots\RobotsPageLoader">
            <argument type="service" id="event_dispatcher"/>
            <argument type="service" id="sales_channel_domain.repository"/>
            <argument type="service" id="Shopwell\Core\System\SystemConfig\SystemConfigService"/>
            <argument type="service" id="Shopwell\Storefront\Page\Robots\Parser\RobotsDirectiveParser"/>
        </service>

        <service id="Shopwell\Storefront\Page\Robots\RobotsConfigChangeSubscriber">
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Shopwell\Storefront\Framework\Routing\RobotsRouteScopeWhitelist">
            <tag name="shopwell.route_scope_whitelist"/>
        </service>
    </services>
</container>
