{
  "name": "sw-next-storefront",
  "version": "1.0.0",
  "private": true,
  "description": "Storefront Building Pipeline for Shopwell Next",
  "keywords": [
    "next",
    "pipeline",
    "storefront",
    "sw"
  ],
  "license": "MIT",
  "scripts": {
    "development": "NODE_ENV=development webpack --config webpack.config.js",
    "hot": "NODE_ENV=development MODE=hot webpack-dev-server --config webpack.config.js",
    "hot-proxy": "NODE_ENV=development MODE=hot node ./build/start-hot-reload.js",
    "lint": "eslint --report-unused-disable-directives --config .eslintrc.js ./src --cache && stylelint --config stylelint.config.js ./src --cache",
    "lint-fix": "npm run lint:js:fix && npm run lint:scss-fix",
    "lint:js": "eslint --report-unused-disable-directives --config .eslintrc.js ./src ./build",
    "lint:js:fix": "npm run lint:js -- --fix",
    "lint:scss": "stylelint --config stylelint.config.js ./src/scss --cache",
    "lint:scss-fix": "npm run lint:scss -- --fix",
    "production": "NODE_ENV=production webpack --config webpack.config.js",
    "unit": "jest --config jest.config.js --ci",
    "unit-watch": "jest --config jest.config.js --watch",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@popperjs/core": "2.11.8",
    "@shopwell-ag/dive": "2.2.29",
    "@swc/core": "1.10.14",
    "autoprefixer": "10.4.13",
    "bootstrap": "5.3.3",
    "copy-webpack-plugin": "12.0.2",
    "core-js": "3.40.0",
    "css-loader": "7.1.2",
    "deepmerge": "4.3.1",
    "file-loader": "6.2.0",
    "flatpickr": "4.6.13",
    "fs-extra": "11.3.0",
    "hammerjs": "2.0.8",
    "history": "4.10.1",
    "mini-css-extract-plugin": "2.9.2",
    "patch-package": "8.0.0",
    "postcss-loader": "8.1.1",
    "postcss-pxtorem": "6.1.0",
    "qrcode": "1.5.4",
    "sass": "1.83.4",
    "sass-loader": "16.0.4",
    "style-loader": "4.0.0",
    "swc-loader": "0.2.6",
    "terser-webpack-plugin": "5.3.11",
    "tiny-slider": "2.9.4",
    "typescript": "5.7.3",
    "webpack": "5.104.1",
    "webpack-cli": "6.0.1",
    "webpack-merge": "6.0.1",
    "webpackbar": "7.0.0"
  },
  "devDependencies": {
    "@babel/cli": "7.23.4",
    "@babel/core": "7.23.7",
    "@babel/eslint-parser": "7.23.3",
    "@babel/plugin-proposal-decorators": "7.23.7",
    "@babel/preset-env": "7.23.7",
    "@babel/preset-typescript": "7.23.3",
    "@types/jest": "29.5.14",
    "@typescript-eslint/eslint-plugin": "5.62.0",
    "@typescript-eslint/parser": "5.62.0",
    "chokidar": "3.5.3",
    "eslint": "8.56.0",
    "eslint-plugin-jest": "26.6.0",
    "http-proxy-middleware": "3.0.5",
    "jest": "29.7.0",
    "jest-environment-jsdom": "29.7.0",
    "jest-junit": "16.0.0",
    "license-checker-rseidelsohn": "4.3.0",
    "lodash.get": "4.4.2",
    "prettier": "3.5.3",
    "stylelint": "16.16.0",
    "stylelint-config-recommended-scss": "14.1.0",
    "stylelint-junit-formatter": "0.2.2",
    "stylelint-prettier": "5.0.3",
    "webpack-dev-server": "5.2.3",
    "xml2js": "0.6.2"
  },
  "overrides": {
    "tmp": "0.2.5",
    "qs": "6.14.2"
  }
}
